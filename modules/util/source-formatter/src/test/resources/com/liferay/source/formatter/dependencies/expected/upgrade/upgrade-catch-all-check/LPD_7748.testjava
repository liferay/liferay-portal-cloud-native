package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Micaelle Silva
 */
public class LPD_7748 {

	public void method(long companyId, String externalReferenceCode) {
		AccountGroupLocalServiceUtil.fetchByExternalReferenceCode(
			123, externalReferenceCode);
		AccountGroupLocalServiceUtil.fetchAccountGroupByExternalReferenceCode(externalReferenceCode, companyId);
		AccountGroupServiceUtil.fetchAccountGroupByExternalReferenceCode(externalReferenceCode, companyId);
		_accountGroupLocalService.fetchAccountGroupByExternalReferenceCode(externalReferenceCode, companyId);
		_accountGroupService.fetchAccountGroupByExternalReferenceCode(externalReferenceCode, companyId);
	}

	@Reference
	private AccountGroupLocalService _accountGroupLocalService;

	@Reference
	private AccountGroupService _accountGroupService;

}
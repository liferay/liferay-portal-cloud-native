package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Kyle Miho
 */
public class LPD_36311 {

	public void method(
		long userId, long repositoryId, long folderId,
		String sourceFileName, String mimeType, byte[] bytes,
		ServiceContext serviceContext) {

		_dlAppLocalService.addFileEntry(123, repositoryId, folderId, sourceFileName, mimeType, bytes, serviceContext);
		_dlAppLocalService.addFileEntry(null, userId, repositoryId, folderId, sourceFileName, mimeType, bytes, null, null, null, serviceContext);
		_dlAppService.addFileEntry(123, folderId, sourceFileName, mimeType, bytes, serviceContext);
		_dlAppService.addFileEntry(null, repositoryId, folderId, sourceFileName, mimeType, bytes, null, null, null, serviceContext);
	}

	@Reference
	private DLAppLocalService _dlAppLocalService;

	@Reference
	private DLAppService _dlAppService;

}
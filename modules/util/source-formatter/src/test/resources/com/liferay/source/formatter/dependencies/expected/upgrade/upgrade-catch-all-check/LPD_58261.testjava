package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Jessyca Ferreira
 */
public class LPD_58261 {

	public void method(
		long userId, long groupId, boolean privateLayout, long parentLayoutId,
		String name, String title, String description, String type,
		boolean hidden, boolean system, String friendlyURL,
		ServiceContext serviceContext) {

		LayoutLocalServiceUtil.addLayout(
			123, groupId, privateLayout, parentLayoutId, name, title,
			description, type, hidden, system, friendlyURL, serviceContext);
		LayoutLocalServiceUtil.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, system, friendlyURL, serviceContext);
		LayoutServiceUtil.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, system, friendlyURL, serviceContext);
		_layoutLocalService.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, system, friendlyURL, serviceContext);
		_layoutService.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, system, friendlyURL, serviceContext);
	}

	@Reference
	private LayoutLocalService _layoutLocalService;

	@Reference
	private LayoutService _layoutService;

}
package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.petra.string.StringPool;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Rubens Soares
 */
public class LPD_69589 {

	public void method(
		long userId, long groupId, long parentStructureId, long classNameId,
		String structureKey, Map<Locale, String> nameMap,
		Map<Locale, String> descriptionMap, DDMForm ddmForm,
		DDMFormLayout ddmFormLayout, String storageType, int type,
		ServiceContext serviceContext) {

		DDMStructureLocalServiceUtil.addStructure(StringPool.BLANK, userId, groupId, parentStructureId, classNameId, structureKey, nameMap, descriptionMap, ddmForm, ddmFormLayout, storageType, type, serviceContext);
		_ddmStructureLocalService.addStructure(
			123, groupId, parentStructureId, classNameId, structureKey, nameMap,
			descriptionMap, ddmForm, ddmFormLayout, storageType, type,
			serviceContext);
		_ddmStructureLocalService.addStructure(StringPool.BLANK, userId, groupId, parentStructureId, classNameId, structureKey, nameMap, descriptionMap, ddmForm, ddmFormLayout, storageType, type, serviceContext);
	}

	public void method(
		long userId, long groupId, long parentStructureId, long classNameId,
		String structureKey, Map<Locale, String> nameMap,
		Map<Locale, String> descriptionMap, String definition,
		String storageType, ServiceContext serviceContext) {

		DDMStructureLocalServiceUtil.addStructure(StringPool.BLANK, userId, groupId, parentStructureId, classNameId, structureKey, nameMap, descriptionMap, definition, storageType, serviceContext);
		_ddmStructureLocalService.addStructure(
			123, groupId, parentStructureId, classNameId, structureKey, nameMap,
			descriptionMap, definition, storageType, serviceContext);
		_ddmStructureLocalService.addStructure(StringPool.BLANK, userId, groupId, parentStructureId, classNameId, structureKey, nameMap, descriptionMap, definition, storageType, serviceContext);
	}

	public void method(
		long userId, long structureId, long parentStructureId,
		Map<Locale, String> nameMap, Map<Locale, String> descriptionMap,
		String definition, ServiceContext serviceContext) {

		DDMStructureLocalServiceUtil.updateStructure(StringPool.BLANK, userId, structureId, serviceContext.getScopeGroupId(), parentStructureId, DDMStructureLocalServiceUtil.getStructure(structureId).getClassNameId(), DDMStructureLocalServiceUtil.getStructure(structureId).getStructureKey(), nameMap, descriptionMap, definition, serviceContext);
		_ddmStructureLocalService.updateStructure(
			123, structureId, parentStructureId, nameMap, descriptionMap,
			definition, serviceContext);
		_ddmStructureLocalService.updateStructure(StringPool.BLANK, userId, structureId, serviceContext.getScopeGroupId(), parentStructureId, DDMStructureLocalServiceUtil.getStructure(structureId).getClassNameId(), DDMStructureLocalServiceUtil.getStructure(structureId).getStructureKey(), nameMap, descriptionMap, definition, serviceContext);
	}

	@Reference
	private DDMStructureLocalService _ddmStructureLocalService;

}
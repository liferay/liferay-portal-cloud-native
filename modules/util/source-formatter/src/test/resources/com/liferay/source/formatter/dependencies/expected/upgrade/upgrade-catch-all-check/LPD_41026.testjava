package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Kyle Miho
 */
public class LPD_41026 {

	public void method(
		long userId, long groupId, boolean privateLayout, long parentLayoutId,
		String name, String title, String description, String type,
		boolean hidden, String friendlyURL, ServiceContext serviceContext) {

		LayoutLocalServiceUtil.addLayout(123, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, friendlyURL, serviceContext);
		LayoutLocalServiceUtil.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, friendlyURL, serviceContext);
		LayoutServiceUtil.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, friendlyURL, serviceContext);
		_LayoutLocalService.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, friendlyURL, serviceContext);
		_LayoutService.addLayout(null, userId, groupId, privateLayout, parentLayoutId, name, title, description, type, hidden, friendlyURL, serviceContext);
	}

	@Reference
	private LayoutLocalService _LayoutLocalService;

	@Reference
	private LayoutService _LayoutService;

}
package com.liferay.source.formatter.dependencies;

import java.util.Objects;

/**
 * @author Alan Huang
 */
public class CombineIfStatementAndReturn {

	public String method1(String orderByType) {
		if (Objects.equals(orderByType, "desc")) {
			return true;
		}

		return false;
	}

	public String method2(String orderByType) {
		if (Objects.equals(orderByType, "desc")) {
			return false;
		}

		return true;
	}

}
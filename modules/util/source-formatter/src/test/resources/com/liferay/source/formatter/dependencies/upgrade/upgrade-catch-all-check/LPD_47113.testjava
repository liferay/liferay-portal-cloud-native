package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
* @author Mateus Xavier
*/
public class LPD_47113 {

    public void method(
        long userId, long groupId, String name, int type, boolean auto,
        ServiceContext serviceContext) {

        SiteNavigationMenuLocalServiceUtil.addSiteNavigationMenu(123, groupId, name, type, auto, serviceContext);
        SiteNavigationMenuServiceUtil.addSiteNavigationMenu(123, name, type, auto, serviceContext);
        _siteNavigationMenuLocalService.addSiteNavigationMenu(userId, groupId, name, type, auto, serviceContext);
        _siteNavigationMenuService.addSiteNavigationMenu(groupId, name, type, auto, serviceContext);
    }

    @Reference
    private SiteNavigationMenuLocalService _siteNavigationMenuLocalService;

    @Reference
    private SiteNavigationMenuService _siteNavigationMenuService;

}
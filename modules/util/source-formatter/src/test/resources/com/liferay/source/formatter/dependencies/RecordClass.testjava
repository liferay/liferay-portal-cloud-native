package com.liferay.source.formatter.dependencies;

/**
 * @author Alan Huang
 */
public record RecordClass(int id, String name) {

	public RecordClass {
		System.out.println("id = " + id);
	}

	public RecordClass(int id) {
		this(id, "");
	}

}
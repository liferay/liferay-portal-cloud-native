package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Micaelle Silva
 */
public class LPD_49117 {

	public void method(
		long userId, long commerceOrderId, long cpInstanceId, String json,
		BigDecimal quantity, long replacedCPInstanceId, int shippedQuantity,
		String unitOfMeasureKey, CommerceContext commerceContext,
		ServiceContext serviceContext) {

		CommerceOrderItemLocalServiceUtil.addOrUpdateCommerceOrderItem(
			userId, commerceOrderId, cpInstanceId, json, quantity,
			replacedCPInstanceId, shippedQuantity, unitOfMeasureKey,
			commerceContext, serviceContext);
		_commerceOrderItemLocalService.addOrUpdateCommerceOrderItem(
			123, commerceOrderId, cpInstanceId, json, quantity,
			replacedCPInstanceId, shippedQuantity, unitOfMeasureKey,
			commerceContext, serviceContext);
		_commerceOrderItemLocalService.addOrUpdateCommerceOrderItem(
			userId, commerceOrderId, cpInstanceId, json, quantity,
			replacedCPInstanceId, shippedQuantity, unitOfMeasureKey,
			commerceContext, serviceContext);
	}

	@Reference
	private CommerceOrderItemLocalService _commerceOrderItemLocalService;

}
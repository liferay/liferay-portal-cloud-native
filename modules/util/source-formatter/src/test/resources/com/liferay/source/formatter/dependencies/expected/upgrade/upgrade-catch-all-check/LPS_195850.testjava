package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.portal.configuration.module.configuration.ConfigurationProviderUtil;
import com.liferay.portal.kernel.service.ServiceContextThreadLocal;

/**
 * @author Kyle Miho
 */
public class LPS_195850 {

	public void method(PortletDisplay portletDisplay, Class<T> clazz) {
		ConfigurationProviderUtil.getPortletInstanceConfiguration(clazz, ServiceContextThreadLocal.getServiceContext().getThemeDisplay());
		portletDisplay.getPortletInstanceConfiguration(null);
	}

}
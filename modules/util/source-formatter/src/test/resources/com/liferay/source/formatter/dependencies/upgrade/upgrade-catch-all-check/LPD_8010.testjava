package com.liferay.source.formatter.dependencies.upgrade;

/**
 * @author Agnes Maciel
 */
public class LPD_8010 {

	public void method() {
		AutoBatchPreparedStatementUtil.autoBatch(
			connection.prepareStatement(
				"delete from AssetLink where entryId1 = ? or entryId2 = ?"));

		AutoBatchPreparedStatementUtil.autoBatch(
			elementConnection.prepareStatement(
				"update LayoutPageTemplateCollection set lptCollectionKey = ?" +
					" where layoutPageTemplateCollectionId = ?"));
	}

	public void method(PreparedStatement preparedStatement) {
		AutoBatchPreparedStatementUtil.autoBatch(preparedStatement);
	}

}
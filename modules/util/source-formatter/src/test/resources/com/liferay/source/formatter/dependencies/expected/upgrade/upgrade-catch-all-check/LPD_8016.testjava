package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.info.collection.provider.CollectionQuery;
import com.liferay.info.collection.provider.InfoCollectionProvider;

/**
 * @author Nícolas Moura
 */
@Component(immediate = true, service = InfoCollectionProvider.class)
public class LPD_8016 implements InfoCollectionProvider<Resource> {

	@Override
	public InfoPage<Resource> getCollectionInfoPage(
		CollectionQuery collectionQuery) {

		List<Resource> resourceList = getResources();

		if (resourceList.size() <= 0) {
			return InfoPage.of(Collections.emptyList());
		}

		return InfoPage.of(resourceList);
	}

	public List<Resource> getInfoList(
		InfoListProviderContext infoListProviderContext) {

		return getResources();
	}

	public List<Resource> getInfoList(
		InfoListProviderContext infoListProviderContext, Pagination pagination,
		Sort sort) {

		return getResources();
	}

	public int getInfoListCount(
		InfoListProviderContext infoListProviderContext) {

		List<Resource> resources = getResources();

		return resources.size();
	}

}
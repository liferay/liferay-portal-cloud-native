package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Kyle Miho
 */
public class LPS_194818 {

	public void method(
		long userId, long repositoryId, long folderId, String sourceFileName,
		String mimeType, String title, String description, String changeLog,
		byte[] bytes, ServiceContext serviceContext) {

		DLAppLocalServiceUtil.addFileEntry(123, repositoryId, folderId, "test123", mimeType, title, description, changeLog, bytes, serviceContext);
		DLAppLocalServiceUtil.addFileEntry(null, userId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, bytes, null, null, null, serviceContext);
		_dlAppLocalService.addFileEntry(null, userId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, bytes, null, null, null, serviceContext);
	}

	@Reference
	private DLAppLocalService _dlAppLocalService;

}
package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Lucas Ferruccio
 */
public class LPD_58380 {

	public void method(
		long ldapServerId, long companyId, String screenName,
		String emailAddress, boolean checkOriginalEmailAddress) {

		_safePortalLDAP.getUser(
			123, companyId, screenName, emailAddress,
			checkOriginalEmailAddress);
		_safePortalLDAP.getUser(ldapServerId, companyId, screenName, emailAddress, checkOriginalEmailAddress, false);
	}

	@Reference
	private SafePortalLDAP _safePortalLDAP;

}
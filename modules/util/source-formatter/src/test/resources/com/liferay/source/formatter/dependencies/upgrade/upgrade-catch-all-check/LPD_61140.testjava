import org.osgi.service.component.annotations.Reference;

/**
 * @author Jessyca Ferreira
 */
public class LPD_61140 {

	public void method(long cpDefinitionId) {
		CPDefinitionLocalServiceUtil.getLayoutUuid(123);
		CPDefinitionLocalServiceUtil.getLayoutUuid(cpDefinitionId);
		CPDefinitionServiceUtil.getLayoutUuid(cpDefinitionId);
		_cpDefinitionLocalService.getLayoutUuid(cpDefinitionId);
		_cpDefinitionService.getLayoutUuid(cpDefinitionId);
	}

	@Reference
	private CPDefinitionLocalService _cpDefinitionLocalService;

	@Reference
	private CPDefinitionService _cpDefinitionService;

}
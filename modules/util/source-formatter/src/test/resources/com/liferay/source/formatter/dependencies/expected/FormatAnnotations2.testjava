import jakarta.portlet.Portlet;

import org.osgi.service.component.annotations.Component;

/**
 * @author Alan Huang
 */
@Component(
	property = {
		"com.liferay.fragment.entry.processor.portlet.alias=polls",
		"com.liferay.portlet.add-default-resource=true",
		"com.liferay.portlet.css-class-wrapper=portlet-polls-display",
		"com.liferay.portlet.display-category=category.cms",
		"com.liferay.portlet.header-portlet-css=/css/main_polls_display.css",
		"com.liferay.portlet.icon=/icons/polls_display.png",
		"com.liferay.portlet.instanceable=true",
		"com.liferay.portlet.preferences-owned-by-group=true",
		"com.liferay.portlet.private-request-attributes=false",
		"com.liferay.portlet.private-session-attributes=false",
		"com.liferay.portlet.render-weight=50",
		"com.liferay.portlet.scopeable=true",
		"com.liferay.portlet.struts-path=polls_display",
		"com.liferay.portlet.use-default-template=true",
		"jakarta.portlet.display-name=Polls Display",
		"jakarta.portlet.expiration-cache=0",
		"jakarta.portlet.info.keywords=Polls",
		"jakarta.portlet.info.short-title=Polls Display",
		"jakarta.portlet.info.title=Polls Display",
		"jakarta.portlet.init-param.config-template=/polls_display/configuration.jsp",
		"jakarta.portlet.init-param.template-path=/META-INF/resources/",
		"jakarta.portlet.init-param.view-template=/polls_display/view.jsp",
		"jakarta.portlet.name=" + PollsPortletKeys.POLLS_DISPLAY,
		"jakarta.portlet.portlet-mode=text/html;config",
		"jakarta.portlet.resource-bundle=content.Language",
		"jakarta.portlet.security-role-ref=power-user,user"
	},
	service = Portlet.class
)
public class FormatAnnotations2 extends MVCPortlet {
}
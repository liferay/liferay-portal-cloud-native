package com.liferay.source.formatter.dependencies.upgrade;

/**
 * @author Lucas Ferruccio
 */
public class LPD_35262 extends UpgradeProcess {

	public void method(
		String entityClass, String columnName, String columnType) {

		alterTableAddColumn((String)entityClass.getField("TABLE_NAME").get(null), columnName, columnType);
	}

}
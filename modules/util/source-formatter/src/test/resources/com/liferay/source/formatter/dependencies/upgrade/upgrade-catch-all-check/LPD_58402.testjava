package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Jessyca Ferreira
 */
public class LPD_58402 {

	public void method(User user) {
		_modelListener.onAfterUpdate(user);
	}

	@Reference(
		target = "(component.name=com.liferay.portal.security.ldap.internal.model.listener.UserModelListener)"
	)
	private ModelListener<User> _modelListener;

}
package com.liferay.source.formatter.dependencies.upgrade;

/**
 * @author Mateus Xavier
 */
public class LPD_61133 {

	public void method(
		long groupId, long commerceAccountId, HttpSession httpSession) {

		CPCompareHelperUtil.getCPDefinitionIds(
			groupId, commerceAccountId, httpSession);
		CPCompareHelperUtil.getCPDefinitionIds(null, null, null);
	}

	public void method(
		long groupId, long commerceAccountId, long cpDefinitionId,
		HttpSession httpSession) {

		CPCompareHelperUtil.addCompareProduct(
			groupId, commerceAccountId, cpDefinitionId, httpSession);
		CPCompareHelperUtil.addCompareProduct(null, null, null, null);

		CPCompareHelperUtil.removeCompareProduct(
			groupId, commerceAccountId, cpDefinitionId, httpSession);
		CPCompareHelperUtil.removeCompareProduct(null, null, null, null);
	}

}
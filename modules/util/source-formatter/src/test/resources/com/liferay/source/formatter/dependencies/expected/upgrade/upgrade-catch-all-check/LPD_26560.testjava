		FriendlyURLEntryCreateDateComparator.getInstance(true);
		FriendlyURLEntryLocalizationComparator.getInstance(false);
		ObjectFieldCreateDateComparator.getInstance(false);
		PushNotificationsDevicePlatformComparator.getInstance(true);

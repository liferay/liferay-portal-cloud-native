Bundle-Name: Liferay Portal Remote JAXRS Whiteboard
Bundle-SymbolicName: com.liferay.portal.remote.jaxrs.whiteboard
Bundle-Version: 12.0.12
Export-Package:\
	com.liferay.portal.remote.jaxrs.whiteboard.lifecycle,\
	javax.wsdl.xml;version="1.2"
Provide-Capability:\
	osgi.ee;\
		filter:="(&(osgi.ee=JavaSE)(version=${ant.build.javac.target}))",\
	osgi.contract;\
		osgi.contract=JakartaAnnotations;\
		uses:="jakarta.ws.rs,jakarta.ws.rs.client";\
		version:List<Version>="2.1.0",\
	osgi.contract;\
		osgi.contract=JakartaCDI;\
		uses:="jakarta.ws.rs,jakarta.ws.rs.client";\
		version:Version="4.0.0",\
	osgi.contract;\
		filter:="(&(osgi.contract=JakartaExpressionLanguage)(version=5.0.0))"
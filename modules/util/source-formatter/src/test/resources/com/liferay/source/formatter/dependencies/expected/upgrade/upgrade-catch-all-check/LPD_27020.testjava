package com.liferay.source.formatter.dependencies.upgrade;

/**
 * @author Kyle Miho
 */
public class LPD_27020 {

	public void method() {
		AppTitleComparator.getInstance(true);
		AssetListEntrySegmentsEntryRelPriorityComparator.getInstance(true);
		AssetListEntryTitleComparator.getInstance(false);
		AssetListEntryUsageModifiedDateComparator.getInstance(true);
	}

	public void method(boolean showHiddenPages) {
		AppTitleComparator.getInstance(showHiddenPages);
		AssetListEntrySegmentsEntryRelPriorityComparator.getInstance(showHiddenPages);
		AssetListEntryTitleComparator.getInstance(showHiddenPages);
		AssetListEntryUsageModifiedDateComparator.getInstance(showHiddenPages);
	}

}
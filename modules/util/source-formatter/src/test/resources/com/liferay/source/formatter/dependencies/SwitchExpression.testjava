package com.liferay.source.formatter.dependencies;

/**
 * @author Alan Huang
 */
public class SwitchExpression {

	public String method(String month) {
		return switch (month) {
			case "Jan", "Feb", "Mar" -> "Q1";
			case "Apr", "May", "Jun" -> "Q2";
			case "Jul", "Aug", "Sep" -> "Q3";
			case "Oct", "Nov", "Dec" -> "Q4";
			default -> "";
		};
	}

}
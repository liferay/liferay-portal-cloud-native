@component-name = "portal-db-infrastructure"
definition {

	property app.server.types = "tomcat";
	property browser.chrome.version = "139.0";
	property ci.retries.disabled = "true";
	property database.partition.enabled = "true";
	property database.types = "mysql, postgresql";
	property osgi.modules.includes = "portal-tools-db-partition-migration-validator";
	property portal.release = "true";
	property portal.upstream = "true";
	property test.liferay.virtual.instance = "true";
	property test.run.environment = "EE";
	property testray.main.component.name = "Database Partitioning";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		DBPartitionMigrationValidator.clean(hardClean = "true");
	}

	@priority = 4
	test ValidateErrorAndWarningDuringValidation {
		property custom.properties = "virtual.hosts.valid.hosts=localhost,127.0.0.1,www.able.com";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		task ("The database are set and we start a new database with database partitioning enabled") {
			var defaultCompanyId = JSONCompany.getCompanyId();

			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "www.able.com",
				portalInstanceId = "www.able.com",
				virtualHost = "www.able.com");
		}

		task ("When run the migration tool to export the partition, the tool should run successfully") {
			var newCompanyId = JSONCompany.getCompanyId(portalInstanceName = "www.able.com");

			var sourceSchemaName = StringUtil.concat("lpartition_", ${newCompanyId});

			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${newCompanyId},
				databaseSchemaName = ${sourceSchemaName});

			var sourceFilePath = DBPartitionMigrationValidator.getGeneratedFile();

			DBPartitionMigrationValidator.clean();
		}

		task ("When run the migration tool to export the target database, then the tool should run successfully") {
			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${defaultCompanyId},
				databaseSchemaName = "lportal");

			var targetFilePath = DBPartitionMigrationValidator.getGeneratedFile();

			DBPartitionMigrationValidator.clean();
		}

		task ("When run the migration tool to validate previous exports, then the tool should run with errors") {
			DBPartitionMigrationValidator.executeValidation(
				ignoreErrors = "true",
				sourceFilePath = ${sourceFilePath},
				targetFilePath = ${targetFilePath});
		}

		task ("Then the tool stops immediately with some ERROR and WARN console messages") {
			DBPartitionMigrationValidator.validateOutput(outputMessage = "[ERROR] Company ID ${newCompanyId} already exists in the target database");

			DBPartitionMigrationValidator.validateOutput(outputMessage = "[WARN] Company name www.able.com already exists in the target database. You must set a different value in ImportPortalInstanceConfiguration.config.");

			DBPartitionMigrationValidator.validateOutput(outputMessage = "[WARN] Virtual host www.able.com already exists in the target database. You must set a different value in ImportPortalInstanceConfiguration.config.");

			DBPartitionMigrationValidator.validateOutput(outputMessage = "[WARN] Web ID www.able.com already exists in the target database. You must set a different value in ImportPortalInstanceConfiguration.config.");

			DBPartitionMigrationValidator.clean();
		}
	}

	@priority = 5
	test ValidateFailedExportWhenCompanyDoesNotExist {
		property custom.properties = "virtual.hosts.valid.hosts=localhost,127.0.0.1,www.able.com";
		property database.partition.enabled = "false";
		property portal.acceptance = "true";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		task ("The database is set and we add a new virtual instance without database partitioning enabled") {
			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "www.able.com",
				portalInstanceId = "www.able.com",
				virtualHost = "www.able.com");
		}

		task ("Export of non existent company ID will produce error") {
			var randomCompanyId = MathUtil.randomNumber(1000000);

			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${randomCompanyId},
				databaseSchemaName = "lportal",
				ignoreErrors = "true");
		}

		task ("Then the tool stops immediately with a console message as: CompanyId with company ID <companyId> does not exist") {
			DBPartitionMigrationValidator.validateOutput(outputMessage = "Company ${randomCompanyId} does not exist");
		}
	}

	@priority = 4
	test ValidateSuccessfulExportAndValidation {
		property custom.properties = "virtual.hosts.valid.hosts=localhost,127.0.0.1,www.able.com";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		task ("And the source and target database are set") {
			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "www.able.com",
				portalInstanceId = "www.able.com",
				virtualHost = "www.able.com");

			Portlet.shutdownServer();

			DBPartitionMigrationValidator.generateTargetDatabase();
		}

		task ("When run the migration tool to export the source database, then the tool should run successfully") {
			var sourceCompanyId = JSONCompany.getCompanyId(portalInstanceName = "www.able.com");

			var sourceSchemaName = StringUtil.concat("lpartition_", ${sourceCompanyId});

			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${sourceCompanyId},
				databaseSchemaName = ${sourceSchemaName});

			var sourceFilePath = DBPartitionMigrationValidator.getGeneratedFile();

			DBPartitionMigrationValidator.clean();
		}

		task ("When run the migration tool to export the target database, then the tool should run successfully") {
			var targetCompanyId = DBPartitionMigrationValidator.getTargetDatabaseCompanyId();

			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${targetCompanyId},
				databaseSchemaName = "lportal_target");

			var targetFilePath = DBPartitionMigrationValidator.getGeneratedFile();

			DBPartitionMigrationValidator.clean();
		}

		task ("When run the migration tool to validate previous exports, then the tool should run successfully") {
			DBPartitionMigrationValidator.executeValidation(
				ignoreErrors = "false",
				sourceFilePath = ${sourceFilePath},
				targetFilePath = ${targetFilePath});
		}
	}

	@priority = 5
	test ValidateSuccessfulExportWhenSourceNonPartitionedDBHasMultipleInstances {
		property custom.properties = "virtual.hosts.valid.hosts=localhost,127.0.0.1,www.able.com";
		property database.partition.enabled = "false";
		property portal.acceptance = "true";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		task ("The database is set and we add a new virtual instance without database partitioning enabled") {
			var defaultCompanyId = JSONCompany.getCompanyId();

			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "www.able.com",
				portalInstanceId = "www.able.com",
				virtualHost = "www.able.com");
		}

		task ("Export of non default company from multi company database without database partitioning enabled is successful") {
			var newCompanyId = JSONCompany.getCompanyId(portalInstanceName = "www.able.com");

			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${newCompanyId},
				databaseSchemaName = "lportal",
				ignoreErrors = "true");
		}

		task ("Export of default company from multi company database without database partitioning enabled is successful") {
			DBPartitionMigrationValidator.executeExport(
				databaseCompanyId = ${defaultCompanyId},
				databaseSchemaName = "lportal",
				ignoreErrors = "true");
		}
	}

}
{
	"$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
	"appliesTo": [
		"bpmn:Task"
	],
	"category": {
		"id": "connectors",
		"name": "Connectors"
	},
	"description": "Invoke Liferay REST API.",
	"elementType": {
		"value": "bpmn:ServiceTask"
	},
	"engines": {
		"camunda": "^8.3"
	},
	"groups": [
		{
			"id": "authentication",
			"label": "Authentication"
		},
		{
			"id": "endpoint",
			"label": "HTTP Endpoint"
		},
		{
			"id": "timeout",
			"label": "Connection Timeout"
		},
		{
			"id": "payload",
			"label": "Payload"
		},
		{
			"id": "output",
			"label": "Output Mapping"
		},
		{
			"id": "error",
			"label": "Error Handling"
		},
		{
			"id": "retries",
			"label": "Retries"
		}
	],
	"icon": {
		"contents": "data:image/svg+xml;base64,"
	},
	"id": "cddb82b6-1f10-447e-a582-a18d246dd516",
	"name": "Liferay Outbound Connector",
	"properties": [
		{
			"binding": {
				"property": "type",
				"type": "zeebe:taskDefinition"
			},
			"type": "Hidden",
			"value": "io.camunda:http-json:1"
		},
		{
			"binding": {
				"name": "authentication.type",
				"type": "zeebe:input"
			},
			"choices": [
				{
					"name": "None",
					"value": "noAuth"
				},
				{
					"name": "Basic",
					"value": "basic"
				},
				{
					"name": "OAuth 2.0",
					"value": "oauth-client-credentials-flow"
				}
			],
			"description": "Choose the authentication type. Select 'None' if no authentication is necessary.",
			"group": "authentication",
			"id": "authentication.type",
			"label": "Type",
			"type": "Dropdown",
			"value": "noAuth"
		},
		{
			"binding": {
				"name": "authentication.username",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "basic",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.username",
			"label": "Username",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.password",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "basic",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.password",
			"label": "Password",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.oauthTokenEndpoint",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true,
				"pattern": {
					"message": "Must be an HTTP(s) URL",
					"value": "^(=|(http://|https://|secrets|\\{\\{).*$)"
				}
			},
			"description": "Enter the OAuth token endpoint URL.",
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.oauthTokenEndpoint",
			"label": "OAuth 2.0 Token Endpoint",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.clientId",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Enter your application's client ID from the OAuth client.",
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.clientId",
			"label": "Client ID",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.clientSecret",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Enter your application's client secret from the OAuth client.",
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.clientSecret",
			"label": "Client Secret",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.audience",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"description": "Enter the unique identifier of the target API you want to access.",
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.audience",
			"label": "Audience",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "authentication.clientAuthentication",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Send client ID and client secret as a Basic Auth request in the header, or as client credentials in the request body.",
			"group": "authentication",
			"id": "authentication.clientAuthentication",
			"label": "Client Authentication",
			"optional": false,
			"type": "Hidden",
			"value": "credentialsBody"
		},
		{
			"binding": {
				"name": "authentication.scopes",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "oauth-client-credentials-flow",
				"property": "authentication.type",
				"type": "simple"
			},
			"description": "Provide the scopes which you want to request authorization for (e.g.read:contacts).",
			"feel": "optional",
			"group": "authentication",
			"id": "authentication.scopes",
			"label": "Scopes",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "type",
				"type": "zeebe:input"
			},
			"choices": [
				{
					"name": "Custom Objects",
					"value": "customObjects"
				},
				{
					"name": "Other",
					"value": "other"
				}
			],
			"constraints": {
				"notEmpty": true
			},
			"group": "endpoint",
			"id": "modelType",
			"label": "Model Type",
			"optional": false,
			"type": "Dropdown",
			"value": "customObjects"
		},
		{
			"binding": {
				"name": "baseUrl",
				"type": "zeebe:input"
			},
			"constraints": {
				"notEmpty": true,
				"pattern": {
					"message": "Must be a HTTP(s) URL",
					"value": "^(=|(http://|https://|secrets|\\{\\{).*$)"
				}
			},
			"feel": "optional",
			"group": "endpoint",
			"id": "baseUrl",
			"label": "Base URL",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "operationType",
				"type": "zeebe:input"
			},
			"choices": [
				{
					"name": "Get object",
					"value": "GET_object"
				},
				{
					"name": "Get objects",
					"value": "GET_objects"
				},
				{
					"name": "Create object",
					"value": "POST_object"
				},
				{
					"name": "Update object",
					"value": "PUT_object"
				},
				{
					"name": "Update object fields",
					"value": "PATCH_object"
				},
				{
					"name": "Delete object",
					"value": "DELETE_object"
				}
			],
			"condition": {
				"equals": "customObjects",
				"property": "modelType",
				"type": "simple"
			},
			"description": "Choose the operation you want to perform.",
			"group": "endpoint",
			"id": "operationType",
			"label": "Operation Type",
			"type": "Dropdown"
		},
		{
			"binding": {
				"name": "method",
				"type": "zeebe:input"
			},
			"condition": {
				"oneOf": [
					"GET_object",
					"GET_objects",
					"PUT_object",
					"PATCH_object",
					"DELETE_object"
				],
				"property": "operationType",
				"type": "simple"
			},
			"id": "operationMethod",
			"optional": false,
			"type": "Hidden",
			"value": "=split(operationType, \"_\")[1]"
		},
		{
			"binding": {
				"name": "externalReferenceCode",
				"type": "zeebe:input"
			},
			"condition": {
				"oneOf": [
					"GET_object",
					"PUT_object",
					"PATCH_object",
					"DELETE_object"
				],
				"property": "operationType",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"feel": "optional",
			"group": "endpoint",
			"id": "externalReferenceCode",
			"label": "External Reference Code",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "path",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "other",
				"property": "modelType",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"feel": "optional",
			"group": "endpoint",
			"id": "path",
			"label": "Path",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "method",
				"type": "zeebe:input"
			},
			"choices": [
				{
					"name": "POST",
					"value": "POST"
				},
				{
					"name": "GET",
					"value": "GET"
				},
				{
					"name": "DELETE",
					"value": "DELETE"
				},
				{
					"name": "PATCH",
					"value": "PATCH"
				},
				{
					"name": "PUT",
					"value": "PUT"
				}
			],
			"condition": {
				"equals": "other",
				"property": "modelType",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"group": "endpoint",
			"id": "method",
			"label": "Method",
			"optional": false,
			"type": "Dropdown",
			"value": "GET"
		},
		{
			"binding": {
				"name": "url",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "customObjects",
				"property": "modelType"
			},
			"feel": "optional",
			"group": "endpoint",
			"label": "URL",
			"type": "String",
			"value": "=baseUrl + string(if operationType = \"GET_objects\" or operationType = \"POST_object\" then \"/\" else \"/by-external-reference-code/\" + externalReferenceCode)"
		},
		{
			"binding": {
				"name": "url",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "other",
				"property": "modelType"
			},
			"feel": "optional",
			"group": "endpoint",
			"label": "URL",
			"type": "String",
			"value": "=baseUrl + path"
		},
		{
			"binding": {
				"name": "headers",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "other",
				"property": "modelType",
				"type": "simple"
			},
			"description": "Provide the map of HTTP headers to add to the request.",
			"feel": "required",
			"group": "endpoint",
			"id": "headers",
			"label": "Headers",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "queryParameters",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "GET",
				"property": "operationType",
				"type": "simple"
			},
			"description": "Provide the map of query parameters to add to the request URL.",
			"feel": "required",
			"group": "endpoint",
			"id": "queryParameters",
			"label": "Query Parameters",
			"optional": true,
			"type": "String",
			"value": "={\n\t\"fields\": \"string\",\n\t\"nestedFields\": \"string\",\n\t\"restrictFields\": \"string\"\n}"
		},
		{
			"binding": {
				"name": "queryParameters",
				"type": "zeebe:input"
			},
			"condition": {
				"equals": "other",
				"property": "modelType",
				"type": "simple"
			},
			"description": "Provide the map of query parameters to add to the request URL.",
			"feel": "required",
			"group": "endpoint",
			"id": "queryParameters",
			"label": "Query Parameters",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "storeResponse",
				"type": "zeebe:input"
			},
			"description": "Select to store the response as a document in the document store.",
			"feel": "static",
			"group": "endpoint",
			"id": "storeResponse",
			"label": "Store Response",
			"optional": false,
			"type": "Boolean",
			"value": false
		},
		{
			"binding": {
				"name": "skipEncoding",
				"type": "zeebe:input"
			},
			"description": "Select to skip the default URL decoding and encoding behavior.",
			"group": "endpoint",
			"id": "skipEncoding",
			"label": "Skip URL Encoding",
			"optional": true,
			"type": "Hidden"
		},
		{
			"binding": {
				"name": "connectionTimeoutInSeconds",
				"type": "zeebe:input"
			},
			"constraints": {
				"notEmpty": true,
				"pattern": {
					"message": "Must be a number",
					"value": "^\\d+$"
				}
			},
			"description": "Define the connection timeout in seconds. Use 0 for an infinite timeout.",
			"feel": "static",
			"group": "timeout",
			"id": "connectionTimeoutInSeconds",
			"label": "Connection Timeout in Seconds",
			"optional": false,
			"type": "Number",
			"value": 20
		},
		{
			"binding": {
				"name": "readTimeoutInSeconds",
				"type": "zeebe:input"
			},
			"constraints": {
				"notEmpty": true,
				"pattern": {
					"message": "Must be a number",
					"value": "^\\d+$"
				}
			},
			"description": "Define the timeout in seconds to read data from an established connection. Use 0 for an infinite timeout.",
			"feel": "static",
			"group": "timeout",
			"id": "readTimeoutInSeconds",
			"label": "Read Timeout in Seconds",
			"optional": false,
			"type": "Number",
			"value": 20
		},
		{
			"binding": {
				"name": "body",
				"type": "zeebe:input"
			},
			"condition": {
				"oneOf": [
					"POST_object",
					"PUT_object",
					"PATCH_object"
				],
				"property": "operationType",
				"type": "simple"
			},
			"description": "Provide the payload to send with the request.",
			"feel": "optional",
			"group": "payload",
			"id": "operationBody",
			"label": "Operation Body",
			"optional": true,
			"type": "Text"
		},
		{
			"binding": {
				"name": "body",
				"type": "zeebe:input"
			},
			"condition": {
				"oneOf": [
					"POST",
					"PUT",
					"PATCH"
				],
				"property": "method",
				"type": "simple"
			},
			"description": "Provide the payload to send with the request.",
			"feel": "optional",
			"group": "payload",
			"id": "body",
			"label": "Request Body",
			"optional": true,
			"type": "Text"
		},
		{
			"binding": {
				"name": "ignoreNullValues",
				"type": "zeebe:input"
			},
			"feel": "static",
			"group": "payload",
			"id": "ignoreNullValues",
			"label": "Ignore Null Values",
			"optional": false,
			"tooltip": "Null values will not be sent",
			"type": "Boolean",
			"value": false
		},
		{
			"binding": {
				"key": "resultVariable",
				"type": "zeebe:taskHeader"
			},
			"description": "Set the name of the variable that stores the response.",
			"group": "output",
			"id": "resultVariable",
			"label": "Result Variable",
			"type": "String"
		},
		{
			"binding": {
				"key": "resultExpression",
				"type": "zeebe:taskHeader"
			},
			"description": "Enter an expression to map the response into process variables.",
			"feel": "required",
			"group": "output",
			"id": "resultExpression",
			"label": "Result Expression",
			"type": "Text"
		},
		{
			"binding": {
				"key": "errorExpression",
				"type": "zeebe:taskHeader"
			},
			"description": "<a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">Enter an expression</a> to handle errors.",
			"feel": "required",
			"group": "error",
			"id": "errorExpression",
			"label": "Error Expression",
			"type": "Text"
		},
		{
			"binding": {
				"property": "retries",
				"type": "zeebe:taskDefinition"
			},
			"description": "Define the number of retries.",
			"feel": "optional",
			"group": "retries",
			"id": "retryCount",
			"label": "Retries",
			"type": "String",
			"value": "3"
		},
		{
			"binding": {
				"key": "retryBackoff",
				"type": "zeebe:taskHeader"
			},
			"description": "Define the duration in ISO-8601 format to wait between retries.",
			"group": "retries",
			"id": "retryBackoff",
			"label": "Retry Backoff",
			"type": "String",
			"value": "PT0S"
		}
	],
	"version": 1
}
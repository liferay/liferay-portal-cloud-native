<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder auto-import-default-references="false" auto-namespace-tables="false" dependency-injector="ds" mvcc-enabled="true" package-path="com.liferay.change.tracking.sample" short-no-such-exception-enabled="false">
	<namespace>CTS</namespace>
	<entity change-tracking-enabled="true" local-service="true" name="CTSChild" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="ctsChildId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="ctsGrandParentId" type="long" />
		<column name="ctsParentName" type="String" />
		<column name="parentCTSChildId" type="long" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
		<finder name="C_C" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="ctsGrandParentId" />
		</finder>
		<finder name="C_P" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="parentCTSChildId" />
		</finder>
	</entity>
	<entity local-service="true" name="CTSGrandParent" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="ctsGrandParentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="parentCTSGrandParentId" type="long" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
	</entity>
	<entity change-tracking-enabled="true" local-service="true" name="CTSParent" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="ctsParentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="ctsGrandParentId" type="long" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
		<finder name="C_C" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="ctsGrandParentId" />
		</finder>
	</entity>
</service-builder>
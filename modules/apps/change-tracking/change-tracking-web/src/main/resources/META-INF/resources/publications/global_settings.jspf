 * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06
 */
--%>

<clay:sheet-header>
	<h2 class="sheet-title"><liferay-ui:message key="settings" /></h2>
</clay:sheet-header>

<clay:sheet-section>
	<h3 class="sheet-subtitle" id="<portlet:namespace />enablePublicationsHeader"><liferay-ui:message key="enable-publications" /></h3>

	<div class="sheet-text" id="<portlet:namespace />enablePublicationsHelp"><liferay-ui:message key="publications-help" /></div>

	<liferay-ui:error key="stagingEnabled" message="staging-is-enabled-for-at-least-one-site-or-asset-library-in-the-current-virtual-instance" />

	<div class="form-group">
		<aui:input aria-describedby="enablePublicationsHelp" aria-labelledby="enablePublicationsHeader" inlineLabel="right" label="" labelCssClass="simple-toggle-switch" name="enablePublications" onChange='<%= liferayPortletResponse.getNamespace() + "autoSave();" %>' type="toggle-switch" value="<%= publicationsConfigurationDisplayContext.isPublicationsEnabled() %>" />
	</div>
</clay:sheet-section>

<c:if test='<%= FeatureFlagManagerUtil.isEnabled("LPS-186360") %>'>
	<div id="<portlet:namespace />manageRemotely">
		<clay:sheet-section>
			<h3 class="sheet-subtitle" id="<portlet:namespace />manageRemotelyHeader"><liferay-ui:message key="manage-remotely" /></h3>

			<div class="sheet-text" id="<portlet:namespace />manageRemotelyHelp"><liferay-ui:message key="manage-remotely-help" /></div>

			<div class="form-group">
				<aui:input aria-describedby="manageRemotelyHelp" aria-labelledby="manageRemotelyHeader" inlineLabel="right" label="" labelCssClass="simple-toggle-switch" name="enableManageRemotely" onChange='<%= liferayPortletResponse.getNamespace() + "autoSave();" %>' type="toggle-switch" value="<%= publicationsConfigurationDisplayContext.isRemoteEnabled() %>" />

				<aui:input label="client-id" name="clientId" placeholder="remote-client-id-placeholder" readonly="<%= publicationsConfigurationDisplayContext.isRemoteEnabled() %>" type="input" value="<%= publicationsConfigurationDisplayContext.getRemoteClientId() %>" />

				<aui:input label="client-secret" name="clientSecret" placeholder="remote-client-secret-placeholder" readonly="<%= publicationsConfigurationDisplayContext.isRemoteEnabled() %>" type="input" value="<%= publicationsConfigurationDisplayContext.getRemoteClientSecret() %>" />
			</div>
		</clay:sheet-section>
	</div>
</c:if>

<div id="<portlet:namespace />editPublicationsPermissions">
	<clay:sheet-section>
		<h3 class="sheet-subtitle" id="<portlet:namespace />editPublicationsPermissionsHeader"><liferay-ui:message key="permissions" /></h3>

		<clay:alert
			dismissible="<%= true %>"
			message='<%= LanguageUtil.format(request, "when-a-user-creates-a-publication,-liferay-automatically-gives-them-the-owner-role", new String[] {"<strong>", "</strong>", "<strong>", "</strong>"}, false) %>'
		/>

		<div class="sheet-text" id="<portlet:namespace />editPublicationsPermissionsHelp"><liferay-ui:message key="edit-publications-permissions-help" /></div>

		<div id="<portlet:namespace />editPublicationsPermissionsModal">
			<react:component
				module="{PublicationPermissions} from change-tracking-web"
				props="<%= publicationsConfigurationDisplayContext.getReactData() %>"
			/>
		</div>
	</clay:sheet-section>
</div>

<div id="<portlet:namespace />sandboxOnly">
	<clay:sheet-section>
		<h3 class="sheet-subtitle" id="<portlet:namespace />sandboxOnlyHeader"><liferay-ui:message key="sandbox-only" /></h3>

		<c:if test="<%= publicationsConfigurationDisplayContext.isSandboxOnlyEnabled() && publicationsConfigurationDisplayContext.hasPublishPermission() %>">
			<clay:alert
				dismissible="<%= true %>"
				displayType="warning"
				message='<%= LanguageUtil.format(request, "currently,-any-publication-owner-can-publish-the-publication-they-have-created", new String[] {"<strong>", "</strong>", "<strong>", "</strong>"}, false) %>'
			/>
		</c:if>

		<div class="sheet-text" id="<portlet:namespace />sandboxOnlyHelp"><liferay-ui:message key="sandbox-only-help" /></div>

		<div class="form-group">
			<aui:input aria-describedby="sandboxOnlyHelp" aria-labelledby="sandboxOnlyHeader" inlineLabel="right" label="" labelCssClass="simple-toggle-switch" name="enableSandboxOnly" onChange='<%= liferayPortletResponse.getNamespace() + "autoSave();" %>' type="toggle-switch" value="<%= publicationsConfigurationDisplayContext.isSandboxOnlyEnabled() %>" />
		</div>
	</clay:sheet-section>
</div>

<div id="<portlet:namespace />unapprovedChanges">
	<clay:sheet-section>
		<h3 class="sheet-subtitle" id="<portlet:namespace />allowUnapprovedChangesHeader"><liferay-ui:message key="allow-unapproved-changes" /></h3>

		<div class="sheet-text" id="<portlet:namespace />allowUnapprovedChangesHelp"><liferay-ui:message key="allow-unapproved-changes-help" /></div>

		<div class="form-group">
			<aui:input aria-describedby="allowUnapprovedChangesHelp" aria-labelledby="allowUnapprovedChangesHeader" inlineLabel="right" label="" labelCssClass="simple-toggle-switch" name="enableUnapprovedChanges" onChange='<%= liferayPortletResponse.getNamespace() + "autoSave();" %>' type="toggle-switch" value="<%= publicationsConfigurationDisplayContext.isUnapprovedChangesAllowed() %>" />
		</div>
	</clay:sheet-section>
</div>

<aui:script>
	Liferay.Util.toggleBoxes(
		'<portlet:namespace />enablePublications',
		'<portlet:namespace />sandboxOnly',
		<%= publicationsConfigurationDisplayContext.isPublicationsEnabled() ? false : null %>
	);

	Liferay.Util.toggleBoxes(
		'<portlet:namespace />enablePublications',
		'<portlet:namespace />unapprovedChanges',
		<%= publicationsConfigurationDisplayContext.isPublicationsEnabled() ? false : null %>
	);

	Liferay.Util.toggleBoxes(
		'<portlet:namespace />enablePublications',
		'<portlet:namespace />manageRemotely',
		<%= publicationsConfigurationDisplayContext.isPublicationsEnabled() ? false : null %>
	);

	Liferay.Util.toggleBoxes(
		'<portlet:namespace />enablePublications',
		'<portlet:namespace />editPublicationsPermissions',
		<%= publicationsConfigurationDisplayContext.isPublicationsEnabled() ? false : null %>
	);

	function <portlet:namespace />autoSave() {
		submitForm(document.<portlet:namespace />fm);
	}
</aui:script>
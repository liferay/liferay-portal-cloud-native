<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder auto-import-default-references="false" auto-namespace-tables="false" dependency-injector="ds" mvcc-enabled="true" package-path="com.liferay.launch" short-no-such-exception-enabled="false">
	<namespace>Launch</namespace>
	<entity external-reference-code="true" local-service="true" name="LaunchEntry" remote-service="true" trash-enabled="false" uuid="true">

		<!-- PK fields -->

		<column name="launchEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="launchSetId" type="long" />
		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="classVersion" type="String" />

		<!-- Finder methods -->

		<finder name="LaunchSetId" return-type="Collection">
			<finder-column name="launchSetId" />
		</finder>
		<finder name="C_C_C" return-type="LaunchEntry" unique="true">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="classVersion" />
		</finder>
	</entity>
	<entity external-reference-code="true" local-service="true" name="LaunchSet" remote-service="true" trash-enabled="false" uuid="true">

		<!-- PK fields -->

		<column name="launchSetId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="description" type="String" />
		<column name="status" type="int" />
		<column name="statusByUserId" type="long" />
		<column name="statusDate" type="Date" />

		<!-- Order -->

		<order by="asc">
			<order-column name="modifiedDate" />
		</order>

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
		<finder name="C_U" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="userId" />
		</finder>
		<finder name="C_S" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column arrayable-operator="OR" name="status" />
		</finder>
	</entity>
</service-builder>
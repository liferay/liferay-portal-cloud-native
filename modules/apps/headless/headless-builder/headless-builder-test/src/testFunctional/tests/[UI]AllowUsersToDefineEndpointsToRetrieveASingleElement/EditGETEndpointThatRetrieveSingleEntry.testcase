@component-name = "portal-headless"
definition {

	property custom.properties = "feature.flag.LPS-178642=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Object";
	property testray.main.component.name = "Headless Builder";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		task ("Given create an singleElement endpoint with id pathParameter and path parameter description and response schema") {
			ApplicationAPI.createAPIApplication(
				baseURL = "my-app",
				endpointName = "testendpoint",
				endpointPath = "/gettest/{entryId}",
				mainObjectDefinitionErc = "L_API_SCHEMA",
				pathParameter = "id",
				relatedEndpoint = "true",
				relatedSchema = "true",
				retrieveType = "singleElement",
				schemaName = "testSchema",
				status = "published",
				title = "My-app");
		}
	}

	tearDown {
		ApplicationAPI.deleteAllAPIApplication();

		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = 4
	test CanSeeAvailablePathParameterPropertiesInRelatedSchema {
		property portal.acceptance = "true";

		task ("When I select Path Parameter Property in edit API application > Endpoint > Configuration > related schema") {
			APIBuilderUI.switchToRelatedEntryInEditApplication(
				entity = "Endpoints",
				title = "My-app");

			APIBuilderUI.addAndPublishEndpointConfiguration(
				entity = "Endpoints",
				name = "gettest",
				schemaName = "testSchema",
				title = "My-app");

			Click(
				locator1 = "Button#BUTTON_WITH_VALUE",
				value = "ID");
		}

		task ("Then I can see available options are ID and External Reference Code") {
			AssertElementPresent(
				key_optionName = "External Reference Code",
				locator1 = "ObjectAdmin#LAYOUT_ADD_FIELD_OPTION");

			AssertElementPresent(
				key_optionName = "ID",
				locator1 = "ObjectAdmin#LAYOUT_ADD_FIELD_OPTION");
		}
	}

	@priority = 4
	test CanSeePathParameterPropertyWithMapDetails {
		property portal.acceptance = "true";

		task ("When I select schema as the response body schema in edit api application > Endpoints > configuration") {
			APIBuilderUI.switchToRelatedEntryInEditApplication(
				entity = "Endpoints",
				title = "My-app");

			APIBuilderUI.addAndPublishEndpointConfiguration(
				entity = "Endpoints",
				name = "gettest",
				schemaName = "testSchema",
				title = "My-app");
		}

		task ("Then I can see Parameter Property* and Path Parameter Description are present") {
			AssertElementPresent(
				key_optionName = "testSchema",
				locator1 = "ObjectAdmin#LAYOUT_ADD_FIELD_OPTION");
		}

		task ("And Then I can see label about property will be mapped to path parameter") {
			AssertTextEquals(
				locator1 = "APIBuilder#PATH_PARAMETER_PROPERTY_PREVIEW",
				value1 = "This property from the schema will be mapped to path Parameter: {entryId}.");
		}
	}

}
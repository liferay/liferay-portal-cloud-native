 * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06
 */
--%>

<c:if test="<%= hasPermission %>">
	<div class="row">
		<div class="col-12">
			<div id="item-finder-root"></div>

			<liferay-frontend:component
				context='<%=
					HashMapBuilder.<String, Object>put(
						"commerceDiscountId", commerceDiscountId
					).put(
						"discountExternalReferenceCode", commerceDiscount.getExternalReferenceCode()
					).put(
						"namespace", liferayPortletResponse.getNamespace()
					).put(
						"portletId", portletDisplay.getRootPortletId()
					).put(
						"pricingFDSName", CommercePricingFDSNames.DISCOUNT_PRODUCT_DEFINITIONS
					).put(
						"spritemap", themeDisplay.getPathThemeSpritemap()
					).build()
				%>'
				module="{commerceDiscountsTargetProducts} from commerce-pricing-web"
			/>
		</div>

		<div class="col-12">
			<commerce-ui:panel
				bodyClasses="p-0"
				title='<%= LanguageUtil.get(request, "products") %>'
			>
				<frontend-data-set:headless-display
					apiURL="<%= commerceDiscountDisplayContext.getDiscountCPDefinitionApiURL() %>"
					fdsActionDropdownItems="<%= commerceDiscountDisplayContext.getDiscountCPDefinitionFDSActionDropdownItems() %>"
					formName="fm"
					id="<%= CommercePricingFDSNames.DISCOUNT_PRODUCT_DEFINITIONS %>"
				/>
			</commerce-ui:panel>
		</div>
	</div>
</c:if>
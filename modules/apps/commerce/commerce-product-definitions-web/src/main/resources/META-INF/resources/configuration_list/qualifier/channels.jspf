--%>

<c:if test="<%= cpConfigurationListQualifiersDisplayContext.hasPermission() %>">
	<div id="item-finder-root-channel"></div>

	<liferay-frontend:component
		context='<%=
			HashMapBuilder.<String, Object>put(
				"cpConfigurationListExternalReferenceCode", cpConfigurationList.getExternalReferenceCode()
			).put(
				"cpConfigurationListId", cpConfigurationListQualifiersDisplayContext.getCPConfigurationListId()
			).put(
				"dataSetId", CPConfigurationFDSNames.PRODUCT_CONFIGURATION_LIST_QUALIFIER_CHANNELS
			).put(
				"portletId", portletDisplay.getRootPortletId()
			).put(
				"spritemap", themeDisplay.getPathThemeImages() + "/clay/icons.svg"
			).build()
		%>'
		module="{channels} from commerce-product-definitions-web"
	/>

	<commerce-ui:panel
		bodyClasses="p-0"
		title='<%= LanguageUtil.get(request, "channels") %>'
	>
		<frontend-data-set:headless-display
			apiURL="<%= cpConfigurationListQualifiersDisplayContext.getCPConfigurationListChannelsAPIURL() %>"
			fdsActionDropdownItems="<%= cpConfigurationListQualifiersDisplayContext.getCPConfigurationListChannelFDSActionDropdownItems() %>"
			formName="fm"
			id="<%= CPConfigurationFDSNames.PRODUCT_CONFIGURATION_LIST_QUALIFIER_CHANNELS %>"
			namespace="<%= liferayPortletResponse.getNamespace() %>"
			pageNumber="<%= 1 %>"
			portletURL="<%= cpConfigurationListQualifiersDisplayContext.getPortletCPConfigurationListURL() %>"
		/>
	</commerce-ui:panel>
</c:if>
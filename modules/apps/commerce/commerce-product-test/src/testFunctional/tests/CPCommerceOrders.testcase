@component-name = "portal-commerce"
definition {

	property browser.chrome.version = "139.0";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Order Management";

	setUp {
		CommerceConfiguration.commerceSetUp();

		task ("Enable private pages") {
			PagesAdmin.enablePrivatePages();
		}
	}

	tearDown {
		CommerceConfiguration.commerceTearDown();
	}

	@description = "Verify an error message appears when a buyer tries placing an order without the View Billing Address permission if a default billing address is not set."
	@priority = 5
	test AssertErrorMessageWhenAnOrderIsPlacedByBuyerWithoutPermissionToViewBillingAddress {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And given the buyer user does not have permission to view billing addresses") {
			Permissions.removePermissionViaAPI(
				resourceAction = "VIEW_BILLING_ADDRESS",
				resourceName = "com.liferay.commerce.order",
				roleTitle = "Buyer",
				roleType = "account");
		}

		task ("When the buyer tries checking out a new order") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.setAddress(
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code");

			Click(locator1 = "Button#CONTINUE");

			Click(
				key_radioOption = "Standard",
				locator1 = "CommerceEntry#RADIO_BUTTON");

			Click(locator1 = "Button#CONTINUE");
		}

		task ("Then an error message is shown which states a default billing address has not been set") {
			AssertTextEquals.assertText(
				locator1 = "Message#ERROR",
				value1 = "Close Error:No default billing address has been created for this account. Please contact the system administrator to create an order.");
		}
	}

	@description = "This is a test for COMMERCE-12716. As an admin, I can assert a placed order can be converted from processing to completed status via API"
	@priority = 3
	test CanAssertOrdersAreConvertedFromProcessingToCompletedViaAPI {
		property portal.acceptance = "false";

		task ("Given a Minium site with a business account") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And a virtual product is created") {
			CommerceJSONProductsAPI._addCommerceProduct(
				catalogName = "Minium",
				productDescription = "Full Description",
				productName = "Virtual Product",
				productType = "Virtual",
				shortDescription = "Short Description",
				sku = "VIRTUALSKU");
		}

		task ("And the Money Order payment is activated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoTableListEntry(entryName = "Minium Portal");

			CommerceChannels.activatePaymentMethod(paymentMethod = "Money Order");
		}

		task ("And an order is placed") {
			CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				orderItems = "VIRTUALSKU:1",
				orderStatus = 1,
				paymentMethod = "money-order",
				paymentStatus = 2);
		}

		task ("And the admin accepts the order") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			Click(
				key_text = "Accept Order",
				locator1 = "Link#ANY");

			Alert.viewSuccessMessage();

			CommerceOrders.openOrdersAdmin();

			AssertElementPresent(
				key_orderStatus = "Processing",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}

		task ("When the order status is updated from Processing to Completed via API") {
			CommerceJSONOrdersAPI._patchCommerceOrder(orderStatus = 0);
		}

		task ("Then can also verify the status of the order is Completed via UI") {
			CommerceOrders.openOrdersAdmin();

			AssertElementPresent(
				key_orderStatus = "Completed",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}
	}

	@description = "This is a test for COMMERCE-9699 CanUpdateOrderItemCustomFieldValue"
	@priority = 5
	test CanUpdateOrderItemCustomFieldValue {
		property portal.acceptance = "true";

		task ("Given a Minium site with an account") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And a payment method is activated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.activatePaymentMethod(paymentMethod = "Money Order");
		}

		task ("And a Commerce Order Item Custom field is created") {
			CustomFields.openCustomFieldAdmin();

			CustomFields.addCP(
				customFieldName = "test custom field",
				customFieldType = "Input Field",
				customInputDataType = "Text",
				resourceName = "Order Item",
				startingValue = "TEST");
		}

		task ("When a new order is placed with a POST API call with an update of the Custom Field Value") {
			var orderId = CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				orderItems = "MIN55860:8",
				orderItemsCustomFields = "test custom field:NEWVALUE;",
				orderStatus = 1,
				paymentMethod = "Money Order",
				paymentStatus = 0);
		}

		task ("Then the change of the value can be verified with a GET API call") {
			var orderItemCustomFieldValue = CommerceJSONOrdersAPI._getCommerceOrderItemCustomFieldValue(
				customFieldName = "test custom field",
				orderId = ${orderId},
				sku = "MIN55860");

			TestUtils.assertEquals(
				actual = ${orderItemCustomFieldValue},
				expected = "NEWVALUE");
		}
	}

	@description = "This is a test for COMMERCE-10086. As admin, I can update the status of a Partially Shipped order as Completed once I edit unshipped order items quantity after Ship and Deliver is completed."
	@priority = 3
	test CanUpdateOrderStatusByEditingUnshippedItemsQuantity {
		property portal.acceptance = "false";

		task ("Given a Minium site with a business account is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");

			CommerceJSONAccountsAPI._addCommerceAccountAddress(
				accountEntryName = "Commerce Account",
				city = "Test Address",
				countryISOCode = "US",
				name = "Test Name",
				street1 = "Test Street",
				zip = "Test Zip Code");
		}

		task ("And a payment method is activated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.activatePaymentMethod(paymentMethod = "Money Order");
		}

		task ("And an order is placed with a product in multiple quantity") {
			CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				orderItems = "MIN55861:5",
				orderStatus = 1,
				paymentMethod = "money-order",
				paymentStatus = 0,
				shippingAddressName = "Test Name",
				shippingMethod = "Variable Rate",
				shippingOption = "Standard Option");
		}

		task ("When the order is accepted, shipped and delivered only partially") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			Click(
				key_index = "Accept Order",
				locator1 = "WorkflowMetrics#SEARCH_FIELD_MAPPINGS_METRICS_INDEXES");

			CommerceOrders.createShipment(
				complement = "Deliver",
				productSkuList = "MIN55861",
				warehouseName = "Italy");
		}

		task ("Then the status of the order is Partially Shipped") {
			CommerceOrders.openOrdersAdmin();

			AssertElementPresent(
				key_orderStatus = "Partially Shipped",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}

		task ("When the remaining order item quantity is edited as 5 instead of 10") {
			ClickNoError(
				key_orderStatus = "Partially Shipped",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");

			CommerceEntry.clickNoError(menuItem = "View");

			CommerceOrders.editOrderItemDetails(
				orderItemQuantity = 1,
				orderItemSku = "MIN55861");
		}

		task ("Then the status of the order is updated as Completed") {
			Click(locator1 = "Icon#BACK");

			AssertElementPresent(
				key_orderStatus = "Completed",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}

		task ("And the status of the shipment is shown as Delivered") {
			CommerceNavigator.gotoPortlet(
				category = "Order Management",
				portlet = "Shipments");

			AssertElementPresent(
				key_text = "Delivered",
				locator1 = "Icon#ANY_VERTICAL_ELLIPSIS");
		}
	}

	@description = "This is a test for the COMMERCE-10895. As a buyer user, I can only view the order created by myself when I log in via headless API"
	@priority = 3
	test CanViewOrderOnlyCreatedByCurrentUsersViaAPI {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And two accounts are created") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account A",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account B",
				accountEntryType = "Business");
		}

		task ("And buyer user logs in and completes an order with checkout") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			var orderId1 = selenium.getText("CommerceEntry#ACTIVE_ORDER_ID");

			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.initializersCheckout(
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 1,
				productUnitPrice = 24,
				shippingMethod = "Standard");
		}

		task ("And the GET order API is called") {
			var orderCount = CommerceJSONOrdersAPI._getCommerceOrdersCount(email = "buyer@liferay.com");

			TestUtils.assertEquals(
				actual = ${orderCount},
				expected = 1);
		}

		task ("When the admin changes the active account on Minium") {
			User.logoutAndLoginPG();

			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

			CommerceAcceleratorsInitializer.selectAccountFromAccountSelector(accountName = "Commerce Account B");
		}

		task ("And completes an order with checkout") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			var orderId2 = selenium.getText("CommerceEntry#ACTIVE_ORDER_ID");

			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.initializersCheckout(
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 1,
				productUnitPrice = 24,
				shippingMethod = "Standard");
		}

		task ("Then the GET order API only created by buyer user is called") {
			var orderIds = CommerceJSONOrdersAPI._getCommerceOrderIds(email = "buyer@liferay.com");

			TestUtils.assertEquals(
				actual = ${orderId1},
				expected = ${orderIds});

			TestUtils.assertNotEquals(
				actual = ${orderId2},
				expected = ${orderIds});
		}
	}

	@description = "This is a test for COMMERCE-11815. Admin can view an order's quote label border is grey"
	@priority = 3
	test CanViewOrderQuoteLabelBorderIsGrey {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And 'Allow Request a Quote on a Fully Priced Cart' is enabled for the site") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			Check.checkToggleSwitch(
				key_toggleSwitchLabel = "Request a Quote",
				locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");

			Button.clickSave();
		}

		task ("And the buyer requests a quote for an order") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			var orderId = selenium.getText("CommerceEntry#ACTIVE_ORDER_ID");

			CommerceNavigator.gotoMiniCart();

			CommerceOrders.createQuoteRequest(
				quoteRequestValue = "I kindly request a quote for this product.",
				requestAQuoteInMiniCart = "true",
				requestAQuoteInOpenOrdersPage = "true");
		}

		task ("When the admin clicks 'Quote Processed' in the order details") {
			User.logoutAndLoginPG();

			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Quote Requested");

			Click(
				key_index = "Quote Processed",
				locator1 = "WorkflowMetrics#SEARCH_FIELD_MAPPINGS_METRICS_INDEXES");
		}

		task ("Then the admin can view the order status 'Quote Processed' field is grey border on Orders admin page") {
			CommerceOrders.openOrdersAdmin();

			AssertCssValue(
				key_productName = ${orderId},
				key_status = "Quote Processed",
				locator1 = "CommerceEntry#PRODUCT_STATUS_BASED_ON_PRODUCT_NAME",
				locator2 = "border-color",
				value1 = "rgb(205, 206, 217)");
		}
	}

	@description = "This is a test for COMMERCE-10750. User can see if a SKU is on order and can search for Order Id or Account Name the orders under Order Tab in Inventory"
	@priority = 5
	test CanViewOrderSKUAndSearchForSpecificOrderIdAndAccountName {
		property custom.properties = "jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with money order enable and two accounts are created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.editPaymentMethod(
				active = "true",
				paymentMethod = "Money Order");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Account Name",
				accountEntryType = "Business");
		}

		task ("And 2 orders are created") {
			var orderIds = ListUtil.newList();

			for (var quantity : list "1,1") {
				var orderId = CommerceJSONOrdersAPI._addCommerceOrder(
					accountEntryName = "Account Name",
					orderItems = "MIN55861:${quantity}",
					orderStatus = 2,
					paymentMethod = "money-order",
					paymentStatus = 2);

				ListUtil.add(${orderIds}, ${orderId});
			}

			var firstOrderId = ListUtil.get(${orderIds}, 0);
			var secondOrderId = ListUtil.get(${orderIds}, 1);

			for (var list : list "0,1") {
				Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

				CommerceCheckout.gotoCheckoutViaMiniCart();

				CommerceCheckout.initializersCheckout(
					newAddressAddress = "Test Address",
					newAddressCity = "Test City",
					newAddressCountry = "United States",
					newAddressName = "Address Name",
					newAddressZipCode = "Test Zip Code",
					productName = "U-Joint",
					productQuantity = 1,
					productUnitPrice = 24,
					shippingMethod = "Standard");
			}
		}

		task ("And the Order SKU is searched on the inventory page") {
			CommerceInventory.openInventoryAdmin();

			CommerceNavigator.searchEntry(entryName = "MIN55861");

			AssertElementPresent(
				key_orderQuantity = 2,
				key_reference = "MIN55861",
				locator1 = "CommerceEntry#ON_ORDER_QUANTITY");
		}

		task ("And the order ID is searched on the On Order tab") {
			CommerceNavigator.gotoEntry(entryName = "MIN55861");

			Navigator.gotoNavTab(navTab = "On Order");

			CommerceNavigator.searchEntry(entryName = ${firstOrderId});
		}

		task ("And the correct order ID is shown") {
			AssertElementPresent(
				key_orderQuantity = 1,
				key_reference = ${firstOrderId},
				locator1 = "CommerceEntry#ON_ORDER_QUANTITY");

			AssertElementNotPresent(
				key_orderQuantity = 2,
				key_reference = ${secondOrderId},
				locator1 = "CommerceEntry#ON_ORDER_QUANTITY");
		}

		task ("When the account is searched on the On Order tab") {
			CommerceNavigator.searchEntry(entryName = "Account Name");
		}

		task ("Then the correct account is shown") {
			AssertElementPresent(
				key_orderQuantity = 1,
				key_reference = "Account Name",
				locator1 = "CommerceEntry#ON_ORDER_QUANTITY");

			AssertElementNotPresent(
				key_orderQuantity = 0,
				key_reference = "Commerce Account",
				locator1 = "CommerceEntry#ON_ORDER_QUANTITY");
		}
	}

	@description = "This is a test for COMMERCE-12025. If given a user with permissions that only view orders, then the user can just view the order, cannot add or edit order fields"
	@priority = 5
	test CanViewOrdersOnlyWhenGivenViewPermissions {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with a business account and Money Order enabled is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.editPaymentMethod(
				active = "true",
				paymentMethod = "Money Order");

			CommerceJSONAccountsAPI._addCommerceAccount(
				accountName = "Commerce Account",
				accountType = "Business");

			CommerceJSONAccountsAPI._addCommerceAccountAddress(
				accountEntryName = "Commerce Account",
				city = "Test City",
				countryISOCode = "US",
				name = "Test Address",
				street1 = "Test Street",
				zip = "Test Zip Code");
		}

		task ("And a user with permissions that can view order and channel is created") {
			JSONRole.addRegularRole(
				roleKey = "View Order Role",
				roleTitle = "View Order Role");

			JSONUser.addUserWithRole(
				roleTitle = "View Order Role",
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			for (var resourceLists : list "com.liferay.commerce.order:VIEW_COMMERCE_ORDERS,com.liferay.commerce.payment.model.CommercePaymentMethodGroupRel:VIEW,com.liferay.commerce.model.CommerceOrder:VIEW,com.liferay.commerce.model.CommerceOrderType:VIEW,com.liferay.commerce.product.model.CommerceChannel:VIEW,com.liferay.commerce.notification.model.CommerceNotificationTemplate:VIEW,90:VIEW_CONTROL_PANEL,com_liferay_commerce_order_web_internal_portlet_CommerceOrderPortlet:ACCESS_IN_CONTROL_PANEL,com_liferay_commerce_order_web_internal_portlet_CommerceOrderPortlet:VIEW,com.liferay.commerce.channel:VIEW_COMMERCE_CHANNELS") {
				var resourceName = StringUtil.extractFirst(${resourceLists}, ":");
				var resourceAction = StringUtil.extractLast(${resourceLists}, ":");

				Permissions.definePermissionViaJSONAPI(
					resourceAction = ${resourceAction},
					resourceName = ${resourceName},
					roleTitle = "View Order Role");
			}
		}

		task ("When an order is placed") {
			CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				billingAddressName = "Test Address",
				orderItems = "MIN55861:1",
				orderStatus = 1,
				paymentMethod = "money-order",
				paymentStatus = 2,
				shippingAddressName = "Test Address",
				shippingOption = "Standard Delivery");
		}

		task ("Then the admin can view the order fields with 'Add' or 'Edit' button") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			for (var titleName : list "Purchase Order Number,Payment Terms,Delivery Terms,Requested Delivery Date,Printed Note") {
				AssertElementPresent(
					key_buttonName = "Add",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_GENERAL_DETAILS_ADD_EDIT_BUTTON");
			}

			for (var titleName : list "Billing Address,Shipping Address") {
				AssertElementPresent(
					key_buttonName = "Edit",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_GENERAL_DETAILS_ADD_EDIT_BUTTON");
			}

			AssertElementPresent(locator1 = "CommerceOrders#ORDER_EDIT_SUMMARY_BUTTON");

			AssertElementPresent(
				key_value = "MIN55861",
				locator1 = "CommerceEntry#BODY_VERTICAL_ELLIPSIS");

			CommerceEntry.gotoMenuTab(menuTab = "Payments");

			for (var titleName : list "Payment Method,Payment Status") {
				AssertElementPresent(
					key_buttonName = "Edit",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_DETAILS_EDIT_BUTTON");
			}
		}

		task ("But the user that with only view order role cannot view the order fields with 'Add' or 'Edit' button") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "userea@liferay.com",
				userLoginFullName = "userfn userln");

			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdminView(status = "Pending");

			for (var titleName : list "Purchase Order Number,Payment Terms,Delivery Terms,Requested Delivery Date,Printed Note") {
				AssertElementNotPresent(
					key_buttonName = "Add",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_GENERAL_DETAILS_ADD_EDIT_BUTTON");
			}

			for (var titleName : list "Billing Address,Shipping Address") {
				AssertElementNotPresent(
					key_buttonName = "Edit",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_GENERAL_DETAILS_ADD_EDIT_BUTTON");
			}

			AssertElementNotPresent(locator1 = "CommerceOrders#ORDER_EDIT_SUMMARY_BUTTON");

			AssertElementNotPresent(
				key_value = "MIN55861",
				locator1 = "CommerceEntry#BODY_VERTICAL_ELLIPSIS");

			CommerceEntry.gotoMenuTab(menuTab = "Payments");

			for (var titleName : list "Payment Method,Payment Status") {
				AssertElementNotPresent(
					key_buttonName = "Edit",
					key_titleName = ${titleName},
					locator1 = "CommerceOrders#ORDER_DETAILS_EDIT_BUTTON");
			}
		}
	}

	@description = "This is a test for COMMERCE-11737. If admin adds a product to the cart with a printed note, then the printed note still can be viewed after the cart checkout via headless API"
	@priority = 5
	test CanViewPrintedNoteAfterCartCheckoutViaHeadlessAPI {
		property portal.acceptance = "true";

		task ("Given a Minium site with a business account is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceJSONAccountsAPI._addCommerceAccount(
				accountName = "Commerce Account",
				accountType = "Business");

			CommerceJSONAccountsAPI._addCommerceAccountAddress(
				accountEntryName = "Commerce Account",
				city = "Test City",
				countryISOCode = "US",
				name = "Test Address",
				street1 = "Test Street",
				zip = "Test Zip Code");
		}

		task ("When the product 'ABS Sensor' with a printed note is added to the cart via API") {
			CommerceJSONDeliveryCart._addCommerceCart(
				accountEntryName = "Commerce Account",
				billingAddressName = "Test Address",
				cartItems = "MIN93015:10",
				printedNote = "Test Print Note Content",
				shippingAddressName = "Test Address",
				shippingOption = "Standard Delivery");

			var orderId = CommerceJSONOrdersAPI._getCommerceOrder();
		}

		task ("Then the admin can view the printed note is added in the open order via API") {
			var printedNote = CommerceJSONOrdersAPI.getOrderField(
				jsonPath = "$.printedNote",
				orderId = ${orderId},
				parameter = "fields",
				parameterValue = "printedNote");

			TestUtils.assertEquals(
				actual = ${printedNote},
				expected = "Test Print Note Content");
		}

		task ("And the admin can view the printed note is added in the open order via UI") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Open");

			CommerceOrders.viewOrdersEntry(printedNote = "Test Print Note Content");
		}

		task ("When the cart checkout is patched") {
			CommerceJSONDeliveryCart._postCommerceCartCheckout(cartId = ${orderId});
		}

		task ("Then the admin can view the printed note is added in the placed order via API") {
			var printedNote = CommerceJSONOrdersAPI.getOrderField(
				jsonPath = "$.printedNote",
				orderId = ${orderId},
				parameter = "fields",
				parameterValue = "printedNote");

			TestUtils.assertEquals(
				actual = ${printedNote},
				expected = "Test Print Note Content");
		}

		task ("And the admin can view the printed note is added in the placed order via UI") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			CommerceOrders.viewOrdersEntry(printedNote = "Test Print Note Content");
		}
	}

	@description = "This is a test for COMMERCE-11392. Can see timestamps from payment transaction history"
	@priority = 3
	test CanViewTimestampsInOrderTransactionHistory {
		property portal.acceptance = "false";

		task ("Given a Minium site with an Account is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And the admin checks out an order ") {
			User.logoutPG();

			CommerceLogin.miniumLogin(urlAppend = "web/minium");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.initializersCheckout(
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 1,
				productUnitPrice = 24,
				shippingMethod = "Standard");
		}

		task ("When the admin opens the Payments tab") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			CommerceEntry.gotoMenuTab(menuTab = "Payments");
		}

		task ("Then the admin can view the Transaction History") {
			var timestamp = TestUtils.getElementTextContent(element = "//tr//td[3]");

			TestUtils.assertNotEquals(
				actual = ${timestamp},
				expected = "");
		}
	}

	@description = "This is a workaround for an issue with Minium's sidebar on CI"
	@priority = 5
	test EditOrderCheckingOutViaOrderDetails {
		property portal.acceptance = "true";

		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		CommerceChannels.openChannelsAdmin();

		CommerceNavigator.gotoEntry(entryName = "Minium Portal");

		CommerceChannels.activatePaymentMethod(paymentMethod = "Money Order");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "Commerce Account");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.changeProductsSorting(sortingType = "Name Ascending");

		FrontStore.addInitializerProductToCart(
			productName = "ABS Sensor",
			productQuantity = 2);

		CommerceCheckout.gotoCheckout();

		CommerceCheckout.initializersCheckout(
			newAddressAddress = "Test Address",
			newAddressCity = "Test City",
			newAddressCountry = "United States",
			newAddressName = "Address Name",
			newAddressZipCode = "Test Zip Code",
			paymentMethod = "Money Order",
			productName = "ABS Sensor",
			productQuantity = 2,
			productUnitPrice = 50,
			shippingMethod = "Standard");

		CommerceOrders.openOrdersAdmin();

		CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

		CommerceOrders.editOrderItemDetails(
			orderItemQuantity = 4,
			orderItemSku = "MIN93015");

		CommerceOrders.openOrdersAdmin();

		CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

		CommerceOrders.viewOrdersEntry(
			addressAddress = "Test Address",
			addressCity = "Test City",
			addressZipCode = "Test Zip Code",
			paymentMethod = "Money Order",
			productListPrice = "50.00",
			productName = "ABS Sensor",
			productQuantity = 4,
			productSku = "MIN93015",
			productTotalPrice = "$ 100.00");
	}

	@description = "This is a test for COMMERCE-5997. As an order manager, I want to filter orders by Channel, Account, Order Data Range and Order Status"
	@priority = 3
	test FilterOrderByAccount {
		property portal.acceptance = "false";

		// TODO Review

		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		CommerceAccelerators.initializeNewSiteViaAccelerator(
			siteName = "Minium2",
			siteTemplateName = "Minium");

		CommerceChannels.openChannelsAdmin();

		AssertElementPresent(
			key_entryName = "Minium Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		AssertElementPresent(
			key_entryName = "Minium2 Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		ApplicationsMenu.gotoSite(site = "Minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "Commerce Account 1");

		Click(locator1 = "CommerceNavigation#BACK");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "Commerce Account 2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		FrontStore.addInitializerProductToCart(
			productName = "U-Joint",
			productQuantity = 1);

		CommerceCheckout.gotoCheckout();

		CommerceCheckout.initializersCheckout(
			newAddressAddress = "Test Address",
			newAddressCity = "Test City",
			newAddressCountry = "United States",
			newAddressName = "Address Name",
			newAddressZipCode = "Test Zip Code",
			productName = "U-Joint",
			productQuantity = 1,
			productUnitPrice = 24,
			shippingMethod = "Standard");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.selectAccountFromAccountSelector(accountName = "Commerce Account 2");

		FrontStore.addInitializerProductToCart(
			productName = "U-Joint",
			productQuantity = 1);

		ApplicationsMenu.gotoSite(site = "Minium2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		AssertTextEquals.assertPartialText(
			key_rowEntry = "Commerce Account 1",
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME",
			value1 = "Commerce Account 1");

		AssertTextEquals.assertPartialText(
			key_rowEntry = "Commerce Account 2",
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME",
			value1 = "Commerce Account 2");

		CommerceOrders.openOrdersAdmin();

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Click(
			key_categoryFilter = "Account",
			locator1 = "CommerceEntry#FILTER_SELECT_CATEGORY");

		Check.checkNotVisible(
			checkboxName = "Commerce Account 1",
			locator1 = "Checkbox#ANY_CHECKBOX");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		AssertElementPresent(
			accountName = "Commerce Account 1",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");

		Button.click(button = "Clear");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Check.checkNotVisible(
			checkboxName = "Commerce Account 2",
			locator1 = "Checkbox#ANY_CHECKBOX");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		AssertElementPresent(
			accountName = "Commerce Account 2",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");

		Button.click(button = "Clear");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Click(locator1 = "CommerceEntry#FILTER_BACK_ARROW");

		Click(
			key_categoryFilter = "Channel",
			locator1 = "CommerceEntry#FILTER_SELECT_CATEGORY");

		Click(
			key_fieldType = "Minium Portal",
			locator1 = "FormViewBuilder#FIELD_LABEL_MULTIPLE_SELECTION");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		AssertElementPresent(
			accountName = "Commerce Account 2",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");

		Button.click(button = "Clear");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Click(
			key_fieldType = "Minium2 Portal",
			locator1 = "FormViewBuilder#FIELD_LABEL_MULTIPLE_SELECTION");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		AssertElementNotPresent(
			accountName = "Commerce Account 2",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");

		Button.click(button = "Clear");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Click(locator1 = "CommerceEntry#FILTER_BACK_ARROW");

		Click(
			key_categoryFilter = "Order Status",
			locator1 = "CommerceEntry#FILTER_SELECT_CATEGORY");

		Check.checkNotVisible(
			checkboxName = "Open",
			locator1 = "Checkbox#ANY_CHECKBOX");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		AssertElementPresent(
			accountName = "Commerce Account 2",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");

		Button.click(button = "Clear");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		Check.checkNotVisible(
			checkboxName = "Pending",
			locator1 = "Checkbox#ANY_CHECKBOX");

		Click(
			key_menuItem = "Add Filter",
			locator1 = "CommerceEntry#ANY_MENU_ITEM");

		Click(locator1 = "CommerceEntry#FILTER_DROPDOWN_MENU");

		AssertElementPresent(
			accountName = "Commerce Account 1",
			locator1 = "CommerceAccelerators#ACCOUNT_ORDER_NAME");
	}

	@description = ""
	@priority = 5
	test MakeAnOrderWithThreeActiveMinimumOrderAmountsWithDifferentPriority {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And given an active minimum order total rule of priority 0 and minimum of 25.00") {
			CommerceJSONOrdersAPI._addOrderRule(
				amount = "25.00",
				applyTo = "Total",
				orderRuleDescription = "Test Order Rule Description",
				orderRuleName = "Test Order Rule",
				orderRuleType = "Minimum Order Amount",
				priority = 0);
		}

		task ("And given an active minimum order subtotal rule of priority 1 and minimum of 50.00") {
			CommerceJSONOrdersAPI._addOrderRule(
				amount = "50.00",
				applyTo = "Subtotal",
				orderRuleDescription = "Test Order Rule 2 Description",
				orderRuleName = "Test Order Rule 2",
				orderRuleType = "Minimum Order Amount",
				priority = 1);
		}

		task ("And given an active minimum order subtotal rule of priority 2 and minimum of 75.00") {
			CommerceJSONOrdersAPI._addOrderRule(
				amount = "75.00",
				applyTo = "Subtotal",
				orderRuleDescription = "Test Order Rule 3 Description",
				orderRuleName = "Test Order Rule 3",
				orderRuleType = "Minimum Order Amount",
				priority = 2);
		}

		task ("When the buyer adds a product into the cart with a price less than $25.00 and goes to the order details") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);

			CommerceNavigator.gotoMiniCart();

			Button.click(button = "View Details");
		}

		task ("Then a warning message is shown that indicates the additional amount to meet the requirement for the order according to the priority of order rules") {
			AssertTextEquals(
				locator1 = "Modal#BODY",
				value1 = "The minimum order amount is $ 75.00. This order needs an additional $ 51.00 to meet the requirement.");
		}

		task ("And there is no checkout button in that order's order details page") {
			AssertElementNotPresent(locator1 = "Button#CHECKOUT");
		}
	}

}
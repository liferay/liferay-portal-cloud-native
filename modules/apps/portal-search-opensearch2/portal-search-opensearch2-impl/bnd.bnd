Bundle-Name: Liferay Portal Search OpenSearch 2 Implementation
Bundle-SymbolicName: com.liferay.portal.search.opensearch2.impl
Bundle-Version: 1.0.17
Import-Package:\
	!jakarta.enterprise.context.*,\
	!jakarta.enterprise.inject.*,\
	\
	!javax.annotation.*,\
	\
	!javax.servlet.*,\
	\
	!org.apache.avalon.framework.*,\
	!org.apache.log.*,\
	\
	!org.brotli.dec.*,\
	\
	!org.conscrypt.*,\
	\
	!software.amazon.awssdk.*,\
	\
	com.liferay.portal.kernel.exception;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.kernel.json;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.kernel.model;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.kernel.search;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.kernel.service;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.kernel.util;version="[0.0.0,9999.0.0)",\
	com.liferay.portal.search.analysis,\
	com.liferay.portal.search.query;version="[0.0.0,9999.0.0)",\
	\
	*
-dsannotations-options: inherit
-fixupmessages: Classes found in the wrong directory: ...;is:=ignore
Bundle-Name: Liferay Shared Dependencies Netty
Bundle-SymbolicName: com.liferay.shared.dependencies.netty
Bundle-Version: 1.0.11
Import-Package:\
	!com.aayushatharva.brotli4j.*,\
	\
	!com.github.luben.zstd.util.*,\
	\
	!com.nimbusds.common.contenttype.*,\
	!com.nimbusds.langtag.*,\
	\
	!javax.servlet.*,\
	\
	!net.jcip.annotations.*,\
	\
	*
-exportcontents: io.netty.*
-fixupmessages: "^Classes found in the wrong directory: \\\\{META-INF/versions/9/";is:=warning
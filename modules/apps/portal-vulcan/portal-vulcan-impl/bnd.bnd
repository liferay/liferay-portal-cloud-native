Bundle-Name: Liferay Portal Vulcan Implementation
Bundle-SymbolicName: com.liferay.portal.vulcan.impl
Bundle-Version: 5.0.152
Import-Package:\
	!com.google.errorprone.annotations.*,\
	!com.google.gson.*,\
	\
	!com.sun.jdi.*,\
	!com.sun.tools.*,\
	\
	!com.thoughtworks.paranamer.*,\
	\
	!javafx.beans.*,\
	\
	!javax.annotation.*,\
	\
	!javax.money.*,\
	\
	!javax.servlet,\
	\
	!javax.xml.bind,\
	\
	!lombok,\
	\
	!org.checkerframework.checker.nullness.qual.*,\
	\
	!org.joda.time.*,\
	\
	!org.jsoup.*,\
	\
	*
-fixupmessages "Classes found in the wrong directory"; restrict:=error; is:=warning
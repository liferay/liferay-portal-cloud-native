Bundle-Name: Liferay Portal OSGi Web Servlet JSP Compiler
Bundle-SymbolicName: com.liferay.portal.osgi.web.servlet.jsp.compiler
Bundle-Version: 6.0.24
Import-Package:\
	!org.apache.el.util,\
	!org.apache.tools.ant.*,\
	\
	!org.eclipse.jdt.core.compiler,\
	!org.eclipse.jdt.internal.compiler,\
	!org.eclipse.jdt.internal.compiler.classfmt,\
	!org.eclipse.jdt.internal.compiler.env,\
	!org.eclipse.jdt.internal.compiler.impl,\
	!org.eclipse.jdt.internal.compiler.problem,\
	\
	javax.el;version='[3.0.0,4.0)',\
	\
	javax.servlet;version='[2.3.0,4.0.0)',\
	javax.servlet.annotation;version='[2.6.0,4.0.0)',\
	javax.servlet.descriptor;version='[2.6.0,4.0.0)',\
	javax.servlet.http;version='[2.3.0,4.0.0)',\
	javax.servlet.jsp;version='[2.3.2,3.0)',\
	javax.servlet.jsp.el;version='[2.3.2,3.0)',\
	javax.servlet.jsp.jstl.core;version='[1.2.1,2.0)',\
	javax.servlet.jsp.jstl.fmt;version='[1.2.1,2.0)',\
	javax.servlet.jsp.jstl.sql;version='[1.2.1,2.0)',\
	javax.servlet.jsp.jstl.tlv;version='[1.2.1,2.0)',\
	javax.servlet.jsp.tagext;version='[2.3.2,3.0)',\
	\
	javax.tools,\
	\
	javax.xml.parsers,\
	javax.xml.transform,\
	javax.xml.transform.dom,\
	javax.xml.transform.stream,\
	javax.xml.validation,\
	\
	org.apache.taglibs.standard;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.extra.spath;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.functions;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.lang.jstl;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.lang.jstl.parser;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.lang.jstl.test;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.lang.jstl.test.beans;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.lang.support;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.resources;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.common.core;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.common.fmt;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.common.sql;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.common.xml;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.el.core;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.el.fmt;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.el.sql;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.el.xml;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.rt.core;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.rt.fmt;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.rt.sql;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tag.rt.xml;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tei;version='[1.2.3,2.0)',\
	org.apache.taglibs.standard.tlv;version='[1.2.3,2.0)',\
	\
	org.w3c.dom,\
	org.w3c.dom.ls,\
	\
	org.xml.sax,\
	org.xml.sax.ext,\
	org.xml.sax.helpers,\
	\
	*
Provide-Capability:\
	liferay.extender;\
		liferay.extender="jsp.extender";\
		version:Version="${Bundle-Version}"
-includeresource: @javax.servlet.jsp.jstl-[0-9.]*.jar!/META-INF/*.tld
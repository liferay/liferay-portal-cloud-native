definition {

	@summary = "Default summary"
	macro fillGoalsChat(chatProviderId = null, siteSettingsStrategy = null) {
		if (isSet(siteSettingsStrategy)) {
			Select(
				locator1 = "ClickToChatConfiguration#SITE_SETTINGS_STRATEGY",
				value1 = ${siteSettingsStrategy});
		}

		if (isSet(chatProviderId)) {
			Select(
				locator1 = "ClickToChatConfiguration#CHAT_PROVIDER_ID",
				value1 = ${chatProviderId});
		}
	}

	@summary = "Default summary"
	macro getPassword(chatProviderChoosen = null) {
		var clickToChatPassword = PropsUtil.get("click.to.chat.${chatProviderChoosen}.password");

		Type(
			locator1 = "ClickToChatConfiguration#CHAT_PROVIDER_ACCOUNT_ID",
			value1 = ${clickToChatPassword});

		SystemSettings.saveConfiguration();

		Refresh();

		echo("Password: ${clickToChatPassword}");

		return ${clickToChatPassword};
	}

}
Bundle-Name: Liferay OAuth2 Provider REST
Bundle-SymbolicName: com.liferay.oauth2.provider.rest
Bundle-Version: 4.0.74
Import-Package:\
	!javax.cache.*,\
	\
	!net.sf.ehcache,\
	!net.sf.ehcache.config,\
	\
	!org.apache.abdera.*,\
	!org.apache.avalon.*,\
	!org.apache.cxf.aegis.*,\
	!org.apache.html.dom.*,\
	!org.apache.log.*,\
	!org.apache.xmlbeans.*,\
	\
	!org.bouncycastle.*,\
	\
	!org.codehaus.jettison.*,\
	\
	!org.cryptomator.siv.*,\
	\
	!org.joda.time.*,\
	\
	!org.opensaml.*,\
	\
	!sun.security.util.*,\
	\
	*
-dsannotations-options: inherit
-includeresource:\
	@org.apache.cxf.rt.rs.extension.providers*.jar,\
	@org.apache.cxf.rt.rs.json.basic*.jar,\
	@org.apache.cxf.rt.rs.security.jose*.jar,\
	@org.apache.cxf.rt.rs.security.jose.jaxrs*.jar,\
	@org.apache.cxf.rt.rs.security.oauth2*.jar,\
	@org.apache.cxf.rt.security*.jar
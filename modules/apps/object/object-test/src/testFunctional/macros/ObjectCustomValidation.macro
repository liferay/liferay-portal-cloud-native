definition {

	@summary = "Default summary"
	macro activeValidation() {
		Check.checkToggleSwitch(locator1 = "ObjectCustomValidation#ACTIVE_VALIDATION_TOGGLE");
	}

	@summary = "Default summary"
	macro addErrorMessage(errorMessage = null) {
		Type.type(
			locator1 = "ObjectCustomValidation#ADD_ERROR_MESSAGE_VALIDATION",
			value1 = ${errorMessage});
	}

	@summary = "Default summary"
	macro addObjectValidation(validationName = null, validationType = null) {
		LexiconEntry.gotoAdd();

		Type(
			locator1 = "ObjectCustomValidation#LABEL_ON_ADD_VALIDATION",
			value1 = ${validationName});

		ObjectAdmin.selectDropdownItem(
			labelName = "Type",
			optionName = ${validationType});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro assertValidationPresent(validationName = null, validationType = null, validationActive = null) {
		AssertElementPresent(
			key_validationName = ${validationName},
			locator1 = "ObjectCustomValidation#VIEW_LABEL_VALIDATION");

		AssertElementPresent(
			key_validationInfo = ${validationType},
			locator1 = "ObjectCustomValidation#VIEW_INFO_VALIDATION");

		AssertElementPresent(
			key_validationInfo = ${validationActive},
			locator1 = "ObjectCustomValidation#VIEW_INFO_VALIDATION");
	}

	@summary = "Default summary"
	macro desactiveValidation() {
		Uncheck.uncheckToggleSwitch(locator1 = "ObjectCustomValidation#ACTIVE_VALIDATION_TOGGLE");
	}

	@summary = "Default summary"
	macro editLabelOnCustomValidation(editValidationName = null) {
		Type(
			locator1 = "ObjectCustomValidation#LABEL_EDIT_VALIDATION",
			value1 = ${editValidationName});
	}

	@summary = "Default summary"
	macro gotoCustomValidation(validationName = null) {
		Click(
			key_validationName = ${validationName},
			locator1 = "ObjectCustomValidation#VIEW_LABEL_VALIDATION");

		SelectFrame(locator1 = "IFrame#IFRAME");
	}

	@summary = "Default summary"
	macro gotoTab(tabName = null) {
		Click(
			key_tab = ${tabName},
			locator1 = "NavTab#TAB_LINK");
	}

	@summary = "Default summary"
	macro insertScriptOnValidation(scriptValidation = null) {
		Type.typeCodeMirrorEditorNoError(
			locator1 = "ObjectCustomValidation#INSERT_SCRIPT_ON_VALIDATION",
			value1 = ${scriptValidation});
	}

	@summary = "Macro to select fields in a composite key validation type"
	macro selectCompositeKeyField(fieldList = null, validationName = null) {
		TestUtils.hardRefresh();

		ObjectCustomValidation.gotoCustomValidation(validationName = ${validationName});

		ObjectCustomValidation.gotoTab(tabName = "Unique Composite Key");

		Click(locator1 = "ObjectCustomValidation#ADD_COMPOSITE_KEY_FIELDS");

		SelectFrame(locator1 = "ObjectCustomViews#VIEW_MODAL_CONTENT");

		for (var fieldLabel : list ${fieldList}) {
			Click.clickAtNotVisible(
				key_columnOption = ${fieldLabel},
				locator1 = "ObjectCustomViews#CHECKBOX_COLUMN_OPTION");
		}

		PortletEntry.save();

		SelectFrame(locator1 = "IFrame#IFRAME");
	}

}
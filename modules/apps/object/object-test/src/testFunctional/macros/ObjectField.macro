definition {

	@summary = "Default summary"
	macro addAnyFolder(folderName = null) {
		IFrame.selectModalFrame();

		LexiconEntry.gotoAdd();

		SelectFrame(locator1 = "IFrame#IFRAME");

		Click(
			key_kebabOption = "Folder",
			locator1 = "ObjectAdmin#KEBAB_MENU_OPTION");

		Type(
			locator1 = "ObjectPortlet#INPUT_NAME",
			value1 = ${folderName});

		PortletEntry.save();

		AssertTextEquals(
			locator1 = "ObjectField#DOCUMENT_NAME",
			value1 = ${folderName});
	}

	@summary = "Default summary"
	macro assertOptionAndDescriptionOnRequestFiles(description = null,option = null) {
		Click(
			key_currentOption = "Select an option",
			key_labelName = "Request Files",
			locator1 = "ObjectAdmin#CLAY_GENERIC_BUTTON");

		AssertElementPresent(
			key_optionName = ${option},
			locator1 = "ObjectAdmin#CLAY_GENERIC_DROPDOWN_ITEM");

		AssertTextEquals(
			key_type = ${option},
			locator1 = "ObjectField#FIELD_TYPE_DESCRIPTION",
			value1 = ${description});
	}

	@summary = "Default summary"
	macro checkLimitCharacters() {
		Click(
			key_labelName = "Limit Characters",
			locator1 = "ObjectField#DEFAULT_TOGGLE_SWITCH");
	}

	@summary = "Default summary"
	macro checkToggleMandatory() {
		Check.checkToggleSwitch(locator1 = "ObjectField#MANDATORY_TOGGLE");
	}

	@summary = "Default summary"
	macro closeModal() {
		Click(locator1 = "ObjectField#MODAL_CLOSE_BUTTON");
	}

	@summary = "Default summary"
	macro editFormulaField(newContent = null, formulaScript = null, newTypeFormula = null) {
		ObjectField.typeLabel(content = ${newContent});

		ObjectAdmin.selectDropdownItem(
			currentOption = "Decimal",
			labelName = "Filter Type",
			optionName = ${newTypeFormula});

		Type(
			key_text = "Formula Builder",
			locator1 = "TextInput#ANY",
			value1 = ${formulaScript});
	}

	@summary = "Default summary"
	macro save() {
		Click(locator1 = "ObjectField#SAVE_BUTTON");

		Refresh();
	}

	@summary = "Default summary"
	macro selectOptionOnRequestFiles(option = null) {
		ObjectAdmin.selectDropdownItem(
			currentOption = "Select an option",
			labelName = "Request Files",
			optionName = ${option});
	}

	@summary = "Default summary"
	macro selectType(fieldType = null) {
		ObjectAdmin.selectDropdownItem(
			currentOption = "Select an option",
			labelName = "Type",
			optionName = ${fieldType});
	}

	@summary = "Default summary"
	macro toggleMandatory() {
		Check.toggleSwitch(locator1 = "ObjectField#MANDATORY_TOGGLE");
	}

	@summary = "Default summary"
	macro typeLabel(content = null) {
		Type(
			locator1 = "ObjectField#LABEL_LOCALIZED",
			value1 = ${content});
	}

	@summary = "Default summary"
	macro typeName(fieldName = null) {
		Type(
			locator1 = "ObjectField#NAME_FIELD",
			value1 = ${fieldName});
	}

	@summary = "Default summary"
	macro typeStorageFolder(content = null) {
		Type(
			locator1 = "ObjectField#STORAGE_FOLDER_INPUT",
			value1 = ${content});
	}

	@summary = "Default summary"
	macro typeValueOnLimitCharacters(newValue = null) {
		Type(
			locator1 = "ObjectField#TYPE_MAXIMUM_NUMBER_CHARACTERS",
			value1 = ${newValue});
	}

	@summary = "Default summary"
	macro viewToogleOnSidePanelShowFilesInDM(isDisabled = null) {
		if (${isDisabled} == "Yes") {
			AssertElementPresent(locator1 = "ObjectField#SHOW_FILES_IN_DM_SIDE_PANEL_DISABLED");
		}
		else if (${isDisabled} == "No") {
			AssertElementPresent(locator1 = "ObjectField#SHOW_FILES_IN_DM_SIDE_PANEL_NOT_DISABLED");
		}
	}

}
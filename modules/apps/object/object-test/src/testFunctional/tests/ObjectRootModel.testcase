@component-name = "portal-object"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Object";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-189378 - Verify the user cannot delete a relationship of an object definition that is bound to a root object definition"
	@priority = 3
	test CannotDeleteRelationshipWithChild {
		property custom.properties = "feature.flag.LPS-187142=true";

		task ("Given an object definition that is bound to a root") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Custom Object 195",
				objectName = "CustomObject195",
				pluralLabelName = "Custom Objects 195");

			ObjectAdmin.addObjectViaAPI(
				labelName = "Custom Object 292",
				objectName = "CustomObject292",
				pluralLabelName = "Custom Objects 292");

			ObjectAdmin.addObjectRelationshipViaAPI(
				objectName_1 = "CustomObject195",
				objectName_2 = "CustomObject292",
				relationshipLabel = "Relationship",
				relationshipName = "relationship",
				relationshipType = "oneToMany");

			ObjectAdmin.openObjectAdmin();

			ObjectRootModel.bindToRootObject(
				childObject = "Custom Object 292",
				rootObjectPath = "Custom Object 195 (Relationship)");

			WaitForPageLoad();
		}

		task ("When the user tries to delete the relationship between them") {
			ObjectPortlet.selectCustomObject(label = "Custom Object 195");

			ObjectAdmin.gotoRelationshipsTab();

			ObjectAdmin.selectKebabMenuOption(kebabOption = "Delete");
		}

		task ("Then a modal is seen and the user is prevented from deleting the relationship") {
			AssertTextEquals(
				locator1 = "Modal#HEADER",
				value1 = "Deletion Not Allowed");

			AssertTextEquals.assertPartialText(
				locator1 = "Modal#BODY",
				value1 = "\"Relationship\" is being used by a root object and cannot be deleted. To delete \"Relationship\", you must first unbind it from the root object that is using it.");
		}
	}

	@description = "Description LPS-189380 - Verify published child object definitions do not have dedicated portlets and the related configurations are read only"
	@priority = 3
	test CannotViewChildPortlet {
		property custom.properties = "feature.flag.LPS-187142=true";

		task ("Given two custom object definitions, Parent and Child, with a text field and a 1:M relationship between them") {
			for (var objectName : list "Parent,Child") {
				ObjectAdmin.addObjectViaAPI(
					labelName = ${objectName},
					objectName = ${objectName},
					pluralLabelName = ${objectName});
			}

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Text Field",
				fieldName = "textField",
				fieldType = "String",
				isRequired = "false",
				objectName = "Parent");

			ObjectAdmin.addObjectRelationshipViaAPI(
				objectName_1 = "Parent",
				objectName_2 = "Child",
				relationshipLabel = "Relationship",
				relationshipName = "relationship",
				relationshipType = "oneToMany");
		}

		task ("and Given Child is bound to Parent") {
			ObjectAdmin.openObjectAdmin();

			ObjectRootModel.bindToRootObject(
				childObject = "Child",
				rootObjectPath = "Parent (Relationship)");

			WaitForPageLoad();
		}

		task ("When the user navigates to Child") {
			ObjectPortlet.selectCustomObject(label = "Child");
		}

		task ("Then the enable widget option and panel key category are read only") {
			AssertElementPresent(
				key_checkboxName = "Show Widget in Page Builder",
				locator1 = "Checkbox#CHECKBOX_DISABLED");

			AssertElementPresent(
				key_text = "Control Panel > Object",
				locator1 = "Dropdown#ANY_DISABLED");
		}

		task ("and When the user publishes Parent") {
			ObjectAdmin.publishObjectViaAPI(objectName = "Parent");

			Navigator.gotoBack();
		}

		task ("Then Child is published as well and does not have a dedicated portlet") {
			AssertTextEquals(
				key_label = "Child",
				locator1 = "ObjectAdmin#OBJECT_STATUS",
				value1 = "Approved");

			Click(locator1 = "ApplicationsMenu#TOGGLE");

			AssertElementNotPresent(
				key_category = "Objects",
				key_portlet = "Child",
				locator1 = "ApplicationsMenu#PORTLET");
		}
	}

	@description = "LPS-189380 - Verify the user can to see relationships tabs in the initial out-of-the-box layout of one level of children"
	@priority = 4
	test CanViewRelationTabOOTB {
		property custom.properties = "feature.flag.LPS-187142=true";

		task ("Given two custom object definitions, Santa Cruz and Andre, with a text field and a 1:M relationship between them") {
			for (var objectName : list "Andre,SantaCruz") {
				ObjectAdmin.addObjectViaAPI(
					labelName = ${objectName},
					objectName = ${objectName},
					pluralLabelName = ${objectName});
			}

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Type your name to become a Santa Cruz fan",
				fieldName = "textField",
				fieldType = "String",
				isRequired = "false",
				objectName = "SantaCruz");

			ObjectAdmin.addObjectRelationshipViaAPI(
				objectName_1 = "SantaCruz",
				objectName_2 = "Andre",
				relationshipLabel = "Relationship",
				relationshipName = "relationship",
				relationshipType = "oneToMany");
		}

		task ("and Given Andre is bound to Santa Cruz") {
			ObjectAdmin.openObjectAdmin();

			ObjectRootModel.bindToRootObject(
				childObject = "Andre",
				rootObjectPath = "SantaCruz (Relationship)");

			WaitForPageLoad();
		}

		task ("and Given an object entry in Santa Cruz") {
			ObjectAdmin.publishObjectViaAPI(objectName = "SantaCruz");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "textField",
				objectName = "SantaCruze",
				value = "Andre");
		}

		task ("When the user navigates to the object entry") {
			ObjectAdmin.goToCustomObject(objectName = "SantaCruz");

			ObjectPortlet.viewEntryDetails(entry = "Andre");
		}

		task ("Then there's a relationship tab to Andre") {
			AssertElementPresent(
				key_selectedTab = "Andre",
				locator1 = "ObjectAdmin#VIEW_SELECTED_TAB_ON_OBJECT");
		}
	}

}
@component-name = "portal-object"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Object";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		ObjectAdmin.deleteAllCustomObjectsViaAPI();

		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-149508 - Verify CRUD events appear in the Audit records for object definitions"
	@priority = 5
	test AssertCRUDEventsWithObjectDefinition {
		property portal.acceptance = "true";

		task ("Given a custom object definition") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Custom Object 193625",
				objectName = "CustomObject193625",
				pluralLabelName = "Custom Objects 193625");
		}

		task ("When the user updates and then deletes the object definition") {
			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Custom Object 193625");

			ObjectAdmin.editCustomObject(fieldLabelName = "New object definition updated");

			ObjectAdmin.deleteObjectViaAPI(objectName = "CustomObject193625");
		}

		task ("Then the Add, Update, and Delete events appear in the Audit records") {
			Audit.openAuditAdmin();

			Audit.searchViaKeywords(
				resourceName = "com.liferay.object.model.ObjectDefinition",
				searchTerm = "ADD");

			Audit.viewAuditDetails(
				additionalInformation = "company,C_CustomObject193625,false,Custom Object 193625",
				key_resourceAction = "ADD",
				key_resourceName = "ObjectDefinition",
				resourceAction = "ADD",
				resourceName = "ObjectDefinition");

			Navigator.gotoBack();

			Audit.searchViaKeywords(
				resourceName = "com.liferay.object.model.ObjectDefinition",
				searchTerm = "UPDATE");

			Audit.viewAuditDetails(
				additionalInformation = "New object definition updated",
				key_resourceAction = "UPDATE",
				key_resourceName = "ObjectDefinition",
				resourceAction = "UPDATE",
				resourceName = "ObjectDefinition");

			Navigator.gotoBack();

			Audit.searchViaKeywords(
				resourceName = "com.liferay.object.model.ObjectDefinition",
				searchTerm = "DELETE");

			Audit.viewAuditDetails(
				additionalInformation = "company,C_CustomObject193625,false,New object definition updated",
				key_resourceAction = "DELETE",
				key_resourceName = "ObjectDefinition",
				resourceAction = "DELETE",
				resourceName = "ObjectDefinition");
		}
	}

}
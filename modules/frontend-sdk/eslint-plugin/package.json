{
	"author": "Liferay Frontend Infrastructure Team <pt-frontend-infrastructure@liferay.com>",
	"dependencies": {
		"@typescript-eslint/eslint-plugin": "5.27.0",
		"@typescript-eslint/parser": "5.27.0",
		"eslint-config-prettier": "8.1.0",
		"eslint-plugin-no-for-of-loops": "^1.0.0",
		"eslint-plugin-no-only-tests": "^2.1.0",
		"eslint-plugin-notice": "0.9.10",
		"eslint-plugin-promise": "^5.1.0",
		"eslint-plugin-react": "7.23.1",
		"eslint-plugin-react-hooks": "4.2.0",
		"eslint-plugin-sort-destructure-keys": "^1.3.5"
	},
	"description": "ESLint plugin for the Liferay JavaScript Style",
	"files": [
		".eslintrc.js",
		"configs",
		"rules",
		"scripts",
		"utils"
	],
	"keywords": [
		"code",
		"eslint",
		"eslintplugin",
		"liferay",
		"quality"
	],
	"license": "MIT",
	"main": "index.js",
	"name": "@liferay/eslint-plugin",
	"peerDependencies": {
		"eslint": ">=4.1.1",
		"typescript": "*"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"repository": {
		"directory": "projects/eslint-plugin",
		"type": "git",
		"url": "https://github.com/liferay/liferay-frontend-projects.git"
	},
	"scripts": {
		"build": "true",
		"format": "node-scripts format",
		"format:check": "node-scripts format --check",
		"postinstall": "node scripts/postinstall.js",
		"postversion": "npx liferay-js-publish",
		"preversion": "yarn run format:check && yarn run test",
		"test": "jest"
	},
	"version": "1.9.1"
}

{
	"cpu": 2,
	"dependencies": [
		"liferay"
	],
	"environments": {
		"dev": {
			"loadBalancer": {
				"cdn": false,
				"targetPort": 80
			}
		},
		"infra": {
			"deploy": false
		},
		"int": {
			"loadBalancer": {
				"cdn": true,
				"certs": [
					{
						"customDomains": [
							"analytics-internal.liferay.com"
						]
					}
				],
				"targetPort": 80
			}
		},
		"prd": {
			"loadBalancer": {
				"cdn": true,
				"certs": [
					{
						"customDomains": [
							"analytics.liferay.com"
						]
					}
				],
				"targetPort": 80
			}
		},
		"stg": {
			"loadBalancer": {
				"cdn": true,
				"certs": [
					{
						"customDomains": [
							"analytics-stg.liferay.com"
						]
					}
				],
				"targetPort": 80
			}
		}
	},
	"id": "webserver",
	"image": "liferaycloud/nginx:1.24.0-6.1.1",
	"kind": "Deployment",
	"livenessProbe": {
		"failureThreshold": 3,
		"httpGet": {
			"path": "/nginx_status",
			"port": 80
		},
		"initialDelaySeconds": 30,
		"timeoutSeconds": 60
	},
	"memory": 512,
	"readinessProbe": {
		"failureThreshold": 3,
		"httpGet": {
			"path": "/nginx_status",
			"port": 80
		},
		"initialDelaySeconds": 10,
		"timeoutSeconds": 10
	}
}
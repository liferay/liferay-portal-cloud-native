Bundle-Name: Liferay AI Hub Site Initializer API
Bundle-SymbolicName: com.liferay.ai.hub.site.initializer.api
Bundle-Version: 1.0.2
Export-Package: com.liferay.ai.hub.site.initializer.mcp.tool.provider
Import-Package:\
	!org.bouncycastle.jsse.*,\
	\
	!org.conscrypt.*,\
	\
	!org.openjsse.javax.net.ssl.*,\
	!org.openjsse.net.ssl.*,\
	\
	android.*;resolution:=optional,\
	\
	*
Web-ContextPath: /ai-hub-site-initializer-api
-fixupmessages: Classes found in the wrong directory: ...;is:=ignore
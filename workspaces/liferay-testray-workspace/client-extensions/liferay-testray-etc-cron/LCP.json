{
	"concurrencyPolicy": "Forbid",
	"cpu": 4,
	"env": {
		"LIFERAY_ROUTES_CLIENT_EXTENSION": "/etc/liferay/lxc/ext-init-metadata",
		"LIFERAY_ROUTES_DXP": "/etc/liferay/lxc/dxp-metadata",
		"LIFERAY_TESTRAY_ETC_CRON_AUTO_ARCHIVE_POLICY": 60,
		"LIFERAY_TESTRAY_ETC_CRON_AUTO_DELETE_POLICY": 30,
		"LIFERAY_TESTRAY_ETC_CRON_LIFERAY_OAUTH_CLIENT_ID": "@liferay-oauth-client-id",
		"LIFERAY_TESTRAY_ETC_CRON_LIFERAY_OAUTH_CLIENT_SECRET": "@liferay-oauth-client-secret",
		"LIFERAY_TESTRAY_ETC_CRON_LIFERAY_URL": "@liferay-url"
	},
	"environments": {
		"extdev": {
			"schedule": "30 20 * * *"
		},
		"infra": {
			"deploy": false
		}
	},
	"id": "__PROJECT_ID__",
	"kind": "CronJob",
	"memory": 3000,
	"scale": 1,
	"schedule": "30 20 * * *"
}
@default = "click"
@summary = "Click on '${locator1}'"
definition {

	function click {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAt {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtNotVisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.clickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtSidebarClickAtWaitForScript {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.pause(1000);

		Click.clickAt();

		selenium.waitForElementPresent(${locator1}, "false");
	}

	function clickNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoMouseOverNoWaitForVisible {
		WaitForSPARefresh();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoSPARefresh {
		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoWaitForVisible {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function javaScriptClick {
		WaitForSPARefresh();

		selenium.javaScriptClick();
	}

	function mouseDownMouseUp {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible();

		selenium.mouseDown();

		selenium.mouseUp();
	}

	function mouseOverClick {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.waitForVisible();

		selenium.click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function pauseClickAt {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.mouseOver();

		Click.clickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForMenuToggleJSClick {
		WaitForSPARefresh();

		selenium.selectFrame("relative=top");

		if (selenium.isElementPresent("//*[contains(@class,'modal-body')]/iframe[not(contains(@class,'hidden'))]")) {
			selenium.selectFrame("//*[contains(@class,'modal-body')]/iframe[not(contains(@class,'hidden'))]");
		}

		selenium.waitForEditable();

		selenium.pause(1000);

		Click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForPersonalMenuJSClick {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.pause(3000);

		Click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
@default = "clickAt"
definition {

	function clickAt {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		if (selenium.isChecked()) {
			selenium.clickAt();
		}

		AssertNotChecked.assertNotChecked();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckHiddenToggleSwitch {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isChecked("xpath=(${locator1})/../../input")) {
			selenium.clickAt();
		}

		AssertNotChecked.assertNotCheckedHiddenToggleSwitch();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckNotVisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isChecked()) {
			selenium.clickAt();

			selenium.pause(1000);
		}

		selenium.assertNotChecked();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckToggleSwitch {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isChecked()) {
			selenium.clickAt();
		}

		AssertNotChecked.assertNotCheckedNotVisible();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckToggleSwitchAndPause {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isChecked()) {
			selenium.clickAt();
		}

		selenium.pause(1000);

		AssertNotChecked.assertNotCheckedNotVisible();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckToggleSwitchNoErrorNoAssert {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isChecked()) {
			selenium.clickAt();
		}
	}

}
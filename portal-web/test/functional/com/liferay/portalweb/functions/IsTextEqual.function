@default = "isTextEqual"
definition {

	function isPartialText {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isPartialTextCaseInsensitive();
	}

	function isText {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isTextCaseInsensitive();
	}

	function isTextEqual {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			IsTextEqual.isValue();
		}
		else {
			IsTextEqual.isText();
		}
	}

	function isValue {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isValue();
	}

}
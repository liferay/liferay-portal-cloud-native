@default = "isTextNotEqual"
definition {

	function isNotText {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.isNotText();
	}

	function isNotValue {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.isNotValue();
	}

	function isTextNotEqual {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			IsTextNotEqual.isNotValue();
		}
		else {
			IsTextNotEqual.isNotText();
		}
	}

}
@default = "uploadTempFile"
definition {

	function uploadTempFile {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver();

		selenium.uploadTempFile();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uploadTempFileHiddenNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.uploadTempFile();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
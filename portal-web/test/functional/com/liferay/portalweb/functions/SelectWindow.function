@default = "selectWindow"
definition {

	function selectPopUp(value1) {
		WaitForSPARefresh();

		selenium.pause(5000);

		selenium.selectPopUp(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindow {
		WaitForSPARefresh();

		selenium.pause(5000);

		selenium.selectWindow();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindowNoSPARefresh {
		selenium.pause(5000);

		selenium.selectWindow();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindowTopNoSPARefresh {
		selenium.pause(5000);

		selenium.selectWindow("null");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForSelectPopUp(value1, value2) {
		WaitForSPARefresh();

		selenium.waitForPopUp(${value1}, value2);

		selenium.selectPopUp();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
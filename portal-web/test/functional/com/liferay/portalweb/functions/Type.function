@default = "clickAtType"
@summary = "Type to '${locator1}' the value '${value1}'"
definition {

	function clickAtType {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.clickAt();

		selenium.pause(1000);

		selenium.type();

		selenium.pause(1000);

		selenium.clickAt();

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeys {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.sendKeys();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeysAceEditor {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.sendKeysAceEditor();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeysApplicationSearch {
		WaitForSPARefresh();

		selenium.waitForEditable();

		Type.sendKeys();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function type {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.type();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeAceEditor {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.typeAceEditor();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeAceEditorNoError {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.typeAceEditor();
	}

	function typeAceEditorNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.typeAceEditor();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeClickAt {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.type();

		selenium.clickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeCodeMirrorEditorNoError {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.typeCodeMirrorEditor();
	}

	function typeEditor {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.typeEditor();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeEditorWaitForEditor {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.pause(1000);

		selenium.waitForEditable();

		Type.typeEditor();

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeKeys {
		selenium.typeKeys();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.type();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeNotVisibleNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForEditable();

		selenium.type();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeNotVisibleNoMouseOverNoError {
		WaitForSPARefresh();

		selenium.waitForEditable();

		selenium.click();

		selenium.type();
	}

	function typePause {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.type();

		selenium.pause(5000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeWaitForCKEditorScript {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		Type.type();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
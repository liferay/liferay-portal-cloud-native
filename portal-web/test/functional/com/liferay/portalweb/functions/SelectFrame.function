@default = "selectFrame"
definition {

	function selectFrame {
		if (contains(${locator1}, "/iframe")) {
			WaitForFrameLoad();

			selenium.waitForVisible(${locator1}, "false");

			selenium.mouseOver();

			selenium.selectFrame();

			selenium.assertJavaScriptErrors("true");

			selenium.assertLiferayErrors();
		}
		else {
			SelectFrame.selectFrameTop();
		}

		WaitForSPARefresh();
	}

	function selectFrameNoLoading {
		if (contains(${locator1}, "/iframe")) {
			selenium.waitForVisible(${locator1}, "false");

			selenium.mouseOver();

			selenium.selectFrame();

			selenium.assertJavaScriptErrors("true");

			selenium.assertLiferayErrors();
		}
		else {
			SelectFrame.selectFrameTop();
		}

		WaitForSPARefresh();
	}

	function selectFrameTop {
		selenium.selectFrame("relative=top");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();

		WaitForSPARefresh();
	}

	function selectSecondFrame {
		if (contains(${locator1}, "/iframe")) {
			selenium.waitForVisible(${locator1}, "false");

			selenium.mouseOver();

			selenium.selectFrame();

			selenium.assertJavaScriptErrors("true");

			selenium.assertLiferayErrors();
		}
		else {
			SelectFrame.selectFrameTop();
		}

		WaitForSPARefresh();
	}

}
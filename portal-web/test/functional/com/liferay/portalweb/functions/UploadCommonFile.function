@default = "uploadCommonFile"
definition {

	function uploadCommonFile {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver();

		selenium.uploadCommonFile();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uploadCommonFileHidden {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.uploadCommonFile();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uploadCommonFileHiddenNoMouseOver {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.uploadCommonFile();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
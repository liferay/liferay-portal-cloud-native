@default = "assertAttributeValue"
definition {

	function assertAttributeNotPresent {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.assertAttributeNotPresent(${locator1}, ${attribute1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertAttributeValue(locator1,value1,value2) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.assertAttributeValue(${locator1}, ${value1}, ${value2});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
@default = "robotType"
@summary = "Type to '${locator1}' the value '${value1}'"
definition {

	function robotType(locator1) {
		WaitForSPARefresh();

		selenium.robotType(${locator1});
	}

	function robotTypeShortcut(locator1) {
		WaitForSPARefresh();

		selenium.robotTypeShortcut(${locator1});
	}

}
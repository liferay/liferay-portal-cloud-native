@default = "isNotChecked"
definition {

	function isNotChecked {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isNotChecked();
	}

	function isNotCheckedNotVisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.isNotChecked();
	}

}
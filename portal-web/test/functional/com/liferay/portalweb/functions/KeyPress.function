@default = "keyPress"
definition {

	function keyDown {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.keyDown();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function keyPress {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.keyPress();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function keyPressCKEditorWaitForCKEditor {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.pause(1000);

		selenium.waitForEditable();

		selenium.mouseOver();

		selenium.keyPress();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function keyPressNoError {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.keyPress();
	}

	function keyUp {
		WaitForSPARefresh();

		selenium.mouseOver();

		selenium.keyUp();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
@default = "clickAt"
definition {

	function checkAll {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}

		selenium.assertChecked("xpath=( //div[@class='checkbox']//input[@title='Select All'])[2]");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function checkHiddenToggleSwitch {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked("xpath=(${locator1})/../../input")) {
			selenium.clickAt();
		}

		AssertChecked.assertCheckedHiddenToggleSwitch();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function checkNotVisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();

			selenium.pause(1000);
		}

		selenium.assertChecked();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function checkNotVisibleNoErrors {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}
	}

	function checkToggleSwitch {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function checkToggleSwitchAndPause {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}

		selenium.pause(1000);

		AssertChecked.assertCheckedNotVisible();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAt {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.waitForEditable();

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}

		AssertChecked.assertChecked();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function toggleSwitch {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		if (selenium.isNotChecked()) {
			selenium.clickAt();
		}

		AssertElementPresent();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
@default = "mouseOver"
@summary = "Mouse over '${locator1}'"
definition {

	function javaScriptFocus {
		WaitForSPARefresh();

		var javascript = '''
var event = document.createEvent('FocusEvent');

event.initEvent('focus', true, false);

arguments[0].dispatchEvent(event);
		''';

		ExecuteJavaScript(
			value1 = ${javaScript},
			value2 = ${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function javaScriptMouseOver {
		WaitForSPARefresh();

		selenium.javaScriptMouseOver();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOver {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverInvisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverNotVisible {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver();

		selenium.waitForVisible();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForMenuToggleJSMouseOver {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.pause(1000);

		selenium.mouseOver();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}
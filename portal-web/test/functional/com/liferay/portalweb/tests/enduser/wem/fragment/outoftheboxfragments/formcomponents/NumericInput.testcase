@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Fragment Administration";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a new site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Add a company Object with a Long Integer, Integer, Precision Decimal and Decimal fields") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "LongInteger",
				fieldLabelName = "Amount",
				fieldName = "amount",
				fieldType = "Long",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Integer",
				fieldLabelName = "Ticket Number",
				fieldName = "ticketNumber",
				fieldType = "Integer",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "PrecisionDecimal",
				fieldLabelName = "Price",
				fieldName = "price",
				fieldType = "BigDecimal",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Decimal",
				fieldLabelName = "Tax",
				fieldName = "tax",
				fieldType = "Double",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");
		}
	}

	@description = "This is a test for LPS-155169. The user could submit successfully when a Form Container has Numeric Input fragments"
	@priority = 4
	test SubmitFormWithNumericInput {
		task ("Given a user has a content page with Numeric Input fragments inside Form Container") {
			task ("Add a Form Container framgment to content page") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page Name",
					type = "content");

				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Page Name",
					siteName = "Test Site Name");

				PageEditor.addFragment(
					collectionName = "Form Components",
					fragmentName = "Form Container");
			}

			task ("Map the Form Container to new Object") {
				PageEditor.editFormContainer(contentType = "Purchase Order");

				PageEditor.publish();
			}
		}

		task ("When the user accesses to the content page at view mode") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");
		}

		task ("Then the user can submit the form with Numeric Inputs successfully") {
			Type(
				key_text = "Amount",
				locator1 = "TextInput#ANY",
				value1 = "2e5");

			Type(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = 100);

			Type(
				key_text = "Price",
				locator1 = "TextInput#ANY",
				value1 = "3.14");

			Type(
				key_text = "Tax",
				locator1 = "TextInput#ANY",
				value1 = "-1");

			Button.clickSubmitButton();

			AssertTextPresent(value1 = "Thank you. Your information was successfully received.");

			Refresh();

			AssertTextEquals(
				key_text = "Amount",
				locator1 = "TextInput#ANY",
				value1 = "");

			AssertTextEquals(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = "");

			AssertTextEquals(
				key_text = "Price",
				locator1 = "TextInput#ANY",
				value1 = "");

			AssertTextEquals(
				key_text = "Tax",
				locator1 = "TextInput#ANY",
				value1 = "");
		}
	}

	@description = "This is a test for LPS-155169. The Numeric Input only allow numbers and some special characters."
	@priority = 5
	test ViewAllowedCharacters {
		property portal.acceptance = "true";

		task ("Given a user has a content page with a Numeric Input inside Form Container") {
			task ("Add a Form Container framgment to content page") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page Name",
					type = "content");

				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Page Name",
					siteName = "Test Site Name");

				PageEditor.addFragment(
					collectionName = "Form Components",
					fragmentName = "Form Container");
			}

			task ("Map the Form Container to new Object") {
				PageEditor.editFormContainer(contentType = "Purchase Order");

				PageEditor.publish(objectName = "Purchase Order");
			}
		}

		task ("When the user accesses to the content page at view mode") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");
		}

		task ("Then the user can only be allowed to type numbers and some special characters") {
			task ("Type -123.456789 in Numeric Input") {
				Type(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "-123.456789");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "-123.456789");
			}

			task ("Type 10e5 in Numeric Input") {
				Type(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "10e5");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "10e5");
			}

			task ("Type 3E2 in Numeric Input") {
				Type(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "3E2");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "3E2");
			}

			task ("Type China#& in Numeric Input") {
				Refresh();

				Type.sendKeys(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "China#&");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "");
			}

			task ("Type 12@12 in Numeric Input") {
				Refresh();

				Type.sendKeys(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "12@12");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = 1212);
			}

			task ("Type 1.2? in Numeric Input") {
				Refresh();

				Type.sendKeys(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "1.2?");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "1.2");
			}

			task ("Type Ch1n4 in Numeric Input") {
				Refresh();

				Type.sendKeys(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = "Ch1n4");

				AssertTextEquals(
					key_text = "Tax",
					locator1 = "TextInput#ANY",
					value1 = 14);
			}
		}
	}

	@description = "This is a test for LPS-151402. The user could see error message when submit a form with value exceeding the maximum or minimum value of field."
	@priority = 4
	test ViewErrorMessageWhenSubmitFormWithValueExceedingTheMaxOrMinValueOfField {
		task ("Given a user has a content page where a Numeric Input and Submit Button fragments are inside a Form Container") {
			task ("Add a Form Container framgment to content page") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page Name",
					type = "content");

				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Page Name",
					siteName = "Test Site Name");

				PageEditor.addFragment(
					collectionName = "Form Components",
					fragmentName = "Form Container");

				PageEditor.editFormContainer(contentType = "Purchase Order");

				PageEditor.publish();
			}
		}

		task ("When the user submits form with value exceeding the maximum value of Numeric Input") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			Type(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = 10000000000);

			Button.clickSubmitButton();
		}

		task ("Then the user should see an error message") {
			AssertAttributeValue(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = "validationMessage",
				value2 = "Value must be less than or equal to 2147483647.");
		}

		task ("When the user submits form with value exceeding the minimum value of Numeric Input") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			Type(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = "-10000000000");

			Button.clickSubmitButton();
		}

		task ("Then the user should see an error message") {
			AssertAttributeValue(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = "validationMessage",
				value2 = "Value must be greater than or equal to -2147483648.");
		}
	}

	@description = "This is a test for LPS-182728. The user should see the field error below the Numeric Input fragment."
	@priority = 3
	test ViewNumericInputFieldErrorMessageWhenPartialValidationFailure {
		task ("Given a user has a content page where a mapped Numeric Input fragment has a partial validation") {
			JSONObject.addObjectValidation(
				errorMessage = "Please enter a valid ticket number.",
				fieldName = "ticketNumber",
				labelName = "Numeric Validation",
				objectName = "PurchaseOrder",
				outputValidationType = "partialValidation",
				script = "ticketNumber > 1000",
				validationType = "ddm");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Purchase Order");

			PageEditor.publish();
		}

		task ("When the user submits form with invalid value") {
			Type(
				key_text = "Ticket Number",
				locator1 = "TextInput#ANY",
				value1 = 150);

			Button.clickSubmitButton();
		}

		task ("Then the user should see a field error message below Numeric Input") {
			Alert.viewFieldErrorMessage(
				errorMessage = "Please enter a valid ticket number.",
				fieldLabel = "Ticket Number");
		}
	}

}
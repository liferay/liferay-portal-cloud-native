@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Page Editor";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Activate local live staging") {
			Staging.openStagingAdmin(siteURLKey = "test-site-name");

			Staging.activateStagingCP(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked content page in staging site."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedContentPageInStagingSite {
		task ("Given a page designer has a locked content page in staging site") {
			Navigator.openURL();

			var siteName = selenium.getText("Home#SITE_NAME");

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignSiteRoleToUser(
				groupName = "Test Site Name",
				roleTitle = "Site Administrator",
				userEmailAddress = "userea@liferay.com");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name (Staging)",
				layoutName = "Test Page Name",
				site = "false",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name Staging");

			PageEditor.publish();

			Staging.gotoPublishToLive();

			Staging.publishToLive();

			ContentPages.gotoPageEditor();

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer edits the locked content page in staging site") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			Navigator.gotoNavTab(navTab = "Staging");

			WaitForPageLoad();

			Click(locator1 = "Icon#EDIT_PENCIL");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Test Page Name");

			ControlMenu.viewHeaderDraftTitle(headerTitle = "Test Page Name");

			AssertVisible(
				key_tab = "Staging",
				locator1 = "NavTab#ACTIVE_TAB_LINK");
		}
	}

}
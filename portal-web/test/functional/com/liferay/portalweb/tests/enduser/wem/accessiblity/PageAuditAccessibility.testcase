@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Audit";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-196044. Check the accessibility in page audit improvement when adding a Button fragment."
	@priority = 3
	test ViewAccessibilityOfButtonFragment {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a user has a Button fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditor.publish();
		}

		task ("When the user opens the Page Audit sidebar") {
			PageAudit.openPageAuditSidebar();
		}

		task ("Then the Button fragment on sidebar should have correct accessibility") {
			AssertAccessible();
		}

		task ("When the user navigates to the details of Button fragment") {
			PageAudit.goToElementDetails(elementName = "Button");
		}

		// Failed for "Certain ARIA roles must contain particular children", comment out until LPS-193447 implemented

		//task ("Then the details panel should have correct accessibility") {
		//	AssertAccessible();
		//}

	}

	@description = "This is a test for LPS-191827. Check the accessibility when warning message displays in a Collection Display with configuration can cause performance issues in page audit."
	@priority = 3
	test ViewAccessibilityOfCollectionDisplayPagePerformanceWarningMessageOnPageAudit {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a user has a Collection Display with None pagination and Display All Collection Items on a content page") {
			AssetListsAdmin.openAssetListsAdmin(siteURLKey = "test-site-name");

			AssetListsAdmin.addDynamicSelection(assetListTitle = "Dynamic Collection");

			AssetListsAdmin.configureItemTypeInDynamicCollection(itemType = "All Types");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");

			PageEditor.editCollectionDisplay(
				assetListName = "Dynamic Collection",
				displayAllCollectionItems = "true",
				fragmentName = "Collection Display",
				pagination = "None");

			PageEditor.publish();
		}

		task ("When the user navigates to the Performance tab of page audit") {
			PageAudit.openPageAuditSidebar();

			PageAudit.goToElementDetails(elementName = "Collection Display");
		}

		task ("Then the warning message should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'panel-unstyled')][.//div[contains(@class,'panel-title')][normalize-space()='Warnings']]//ul");
		}
	}

	@description = "This is a test for LPS-196044 and LPS-191483. Check the accessibility in page audit improvement when adding an Image fragment. Check the accessibility when warning message displays for big image file size."
	@priority = 3
	test ViewAccessibilityOfImageFragment {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a user has a Image fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Image");
		}

		task ("When the user displays a big image in Image fragment") {
			PageEditor.editFragmentImage(
				fragmentName = "Image",
				id = "image-square",
				imageFileName = "high_resolution_photo.jpg",
				uploadFileName = "high_resolution_photo.jpg");
		}

		task ("Then the Resolution section should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'tab')][contains(@class,'active')]/div[contains(@class,'form-group')][.//*[normalize-space()='Resolution']]");
		}

		task ("When the user opens the Page Audit sidebar") {
			PageEditor.publish();

			PageAudit.openPageAuditSidebar();
		}

		task ("Then the Image fragment on sidebar should have correct accessibility") {
			AssertAccessible();
		}

		task ("When the user navigates to the details of Image fragment") {
			PageAudit.goToElementDetails(elementName = "Image");
		}

		// Failed for "Certain ARIA roles must contain particular children", comment out until LPS-193447 implemented

		//task ("Then the details panel should have correct accessibility") {
		//	AssertAccessible();
		//}

	}

}
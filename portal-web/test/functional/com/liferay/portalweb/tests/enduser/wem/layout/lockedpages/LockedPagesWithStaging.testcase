@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Content Pages";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Activate local live staging") {
			Staging.openStagingAdmin(siteURLKey = "test-site-name");

			Staging.activateStagingCP(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-182024. The administrator could unlock locked page in staging site."
	@priority = 4
	test CanUnlockLockedPagesInStagingSite {
		task ("Given a locked page on a staging site") {
			JSONStaging.enableLocalStaging(groupName = "Test Site Name");

			Navigator.openStagingSiteURL(siteName = "Test Site Name");

			ContentPages.gotoPageEditor();

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");

			AssertTextPresent(
				key_columnName = "name",
				key_tableEntry = "Test Content Page Name",
				locator1 = "LexiconTable#TABLE_ENTRY_INFO",
				value1 = "Test Content Page Name");
		}

		task ("Then admin can unlock the locked page") {
			LexiconEntry.gotoEntryMenuItemNoError(
				menuItem = "Unlock",
				rowEntry = "Test Content Page Name");

			Click(
				key_text = "Unlock",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");

			Alert.viewSuccessMessageText(successMessage = "Success:1 pages were successfully unlocked.");

			AssertTextEquals(
				locator1 = "Message#EMPTY_INFO",
				value1 = "No locked pages were found.");
		}
	}

}
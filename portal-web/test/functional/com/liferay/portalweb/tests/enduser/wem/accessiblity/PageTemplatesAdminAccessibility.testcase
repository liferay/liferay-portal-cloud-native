@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Display Page Templates";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-192722. Check the accessibility when changing content type of display page template."
	@priority = 3
	test ViewAccessibilityOfChangeContentTypeOfDisplayPageTemplate {
		task ("Given a site administrator has a display page template for object") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Name",
				fieldName = "name",
				fieldType = "String",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Purchase Order",
				displayPageName = "Display Page Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Purchase Order (Default)");

			PageEditor.publish();
		}

		task ("When the site administrator changes the content type to another object") {
			LexiconCard.viewCardSubtitle(
				card = "Display Page Name",
				cardSubtitle = "Purchase Order");

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Change Content Type");

			DisplayPageTemplatesAdmin._selectMappingTypes(
				contentType = "Web Content Article",
				subType = "Basic Web Content");
		}

		task ("Then the change content type modal should have correct accessibility") {
			AssertElementAccessible(locator1 = "Modal#MODAL_CONTENT");
		}
	}

	@description = "This is a test for LPS-192722. Check the accessibility when changing content type for display page in use."
	@priority = 3
	test ViewAccessibilityOfChangeContentTypeOfDisplayPageTemplateInUse {
		task ("Given a site administrator has a display page template associated to a web content") {
			JSONWebcontent.addWebContent(
				content = "Web Content Content",
				groupName = "Test Site Name",
				title = "Web Content Title");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Web Content Article",
				displayPageName = "Display Page Name",
				subType = "Basic Web Content");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditorMapping.mapEditableTextToField(
				field = "Content",
				fragmentName = "Heading",
				id = "element-text");

			PageEditor.publish();

			WebContentNavigator.openWebContentAdmin(siteURLKey = "test-site-name");

			WebContentNavigator.gotoEditCP(webContentTitle = "Web Content Title");

			WebContent.editDisplayPage(
				pageName = "Display Page Name",
				pageType = "Display Page Templates");

			PortletEntry.publish();
		}

		task ("When the site administrator changes the content type of display page template") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			LexiconCard.viewCardSubtitle(
				card = "Display Page Name",
				cardSubtitle = "Web Content Article - Basic Web Content");

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Change Content Type");
		}

		task ("Then the change content type modal should have correct accessibility") {
			AssertElementAccessible(locator1 = "Modal#MODAL_CONTENT");
		}
	}

	@description = "This is a test for LPS-193213. The page should comply with WCAG 2.1 AA standard when the ellipsis menu of the card is open."
	@priority = 3
	test ViewAccessibilityOfDisplayPageTemplateConfigureAction {
		task ("Given a user has a display page template") {
			JSONLayoutpagetemplate.addDisplayPageTemplateEntry(
				contentType = "Web Content Article",
				displayPageTemplateEntryName = "Display Page Name",
				groupName = "Test Site Name",
				subType = "Basic Web Content");
		}

		task ("When the user opens the dropdown menu of display page template in the Page Templates admin") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			Click.waitForMenuToggleJSClick(
				key_card = "Display Page Name",
				locator1 = "Card#SPECIFIC_CARD_ELLIPSIS");
		}

		task ("Then the configure action should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'dropdown-menu')][contains(@class,'show')]//li[normalize-space()='Configure']");
		}
	}

	@description = "This is a test for LPS-191986. Check the accessibility when edit a non-default display page template’s friendly URL."
	@priority = 3
	test ViewAccessibilityOfDisplayPageTemplateFriendlyURLSection {
		task ("Given a user has a display page template") {
			JSONLayoutpagetemplate.addDisplayPageTemplateEntry(
				contentType = "Web Content Article",
				displayPageTemplateEntryName = "Display Page Name",
				groupName = "Test Site Name",
				subType = "Basic Web Content");
		}

		task ("When the user accesses to the configuration page of display page template") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Configure");
		}

		task ("Then the friendly URL section should have correct accessibility") {
			WaitForPageLoad();

			AssertElementAccessible(locator1 = "//div[contains(@class,'form-content')]");
		}
	}

	@description = "This is a test for LPS-173150 and LPS-175120. View the accessibility of page template import."
	@priority = 3
	test ViewAccessibilityOfPageTemplateImport {
		task ("Given a user accesses to the Page Templates admin") {
			PageTemplatesAdmin.openPageTemplatesAdmin(siteURLKey = "test-site-name");
		}

		task ("When the user accesses to the page template import page") {
			Click.waitForMenuToggleJSClick(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

			MenuItem.click(menuItem = "Import");

			WaitForPageLoad();
		}

		task ("Then the page template import page should have correct accessibility") {
			AssertAccessible();
		}

		task ("When the user imports a page template set") {
			UploadDependencyFile.uploadArchiveFile(fileName = "page-templates-with-invalid-value.zip");

			Button.clickImport();

			AssertTextEquals(
				locator1 = "Message#SUCCESS_IMPORT",
				value1 = "1 item was imported.");

			AssertTextEquals(
				locator1 = "Message#ERROR_IMPORT",
				value1 = "1 item could not be imported.");
		}

		task ("Then the import results page should have correct accessibility") {
			Panel.expandPanel(panel = "1 item was imported.");

			AssertElementAccessible(locator1 = "//div[contains(@id,'main-content')]//div[contains(@class,'panel-body')]");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@id,'main-content')]//div[contains(@class,'panel-body')])[2]");

			Button.clickDone();
		}

		task ("When the user imports the same page template set") {
			Click.waitForMenuToggleJSClick(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

			MenuItem.click(menuItem = "Import");

			WaitForPageLoad();

			UploadDependencyFile.uploadArchiveFile(fileName = "page-templates-with-invalid-value.zip");

			Button.clickImport();
		}

		task ("Then the import options modal should have correct accessibility") {
			WaitForVisible(locator1 = "Modal#HEADER");

			AssertElementAccessible(locator1 = "//div[contains(@class,'modal-content')]");
		}
	}

	@description = "This is a test for LPS-192722. Check the accessibility when editing display page template without content type."
	@priority = 3
	test ViewAccessibilityOfSelectContentTypeOfDisplayPageTemplateWithoutContentType {
		task ("Given a site administrator has a display page template without content type") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Name",
				fieldName = "name",
				fieldType = "String",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Purchase Order",
				displayPageName = "Display Page Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Purchase Order (Default)");

			PageEditor.publish();

			ObjectAdmin.deleteObjectViaAPI(objectName = "PurchaseOrder");
		}

		task ("When the site administrator edits the display page template") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			LexiconCard.viewCardSubtitle(
				card = "Display Page Name",
				cardSubtitle = "-");

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Edit");
		}

		task ("Then the select content type modal should have correct accessibility") {
			AssertElementAccessible(locator1 = "Modal#MODAL_CONTENT");
		}
	}

}
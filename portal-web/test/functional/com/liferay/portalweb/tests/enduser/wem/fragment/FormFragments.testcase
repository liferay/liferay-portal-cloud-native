@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Fragment Administration";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a new site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-169924. The user without View permission for object cannot see Form Container at view and perview mode."
	@priority = 5
	test CannotSeeFormContainerAtViewAndPreviewModeAsUserWithoutViewPermissionForObject {
		property custom.properties = "jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a user doesn't have view permission for custom object") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Region",
				fieldName = "region",
				fieldType = "String",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.editFormContainer(contentType = "Purchase Order");

			PageEditor.publish();

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "Userfn",
				userLastName = "Userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.addRegularRole(
				roleKey = "Page Designer",
				roleTitle = "Page Designer");

			for (var resourceActionIndex : list "UPDATE,VIEW") {
				Permissions.definePermissionViaJSONAPI(
					resourceAction = ${resourceActionIndex},
					resourceName = "com.liferay.portal.kernel.model.Layout",
					roleTitle = "Page Designer");
			}

			JSONRole.assignRoleToUser(
				roleTitle = "Page Designer",
				userEmailAddress = "userea@liferay.com");

			User.logoutAndLoginPG(userLoginEmailAddress = "userea@liferay.com");
		}

		task ("When the user navigates to the content page at view mode") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");
		}

		task ("Then the user cannot see the Form Container") {
			AssertElementNotPresent(locator1 = "Fragment#FORM_CONTAINER");
		}

		task ("When the user navigates to the content page at preview mode") {
			ContentPages.gotoPageEditor();

			PageEditor.previewInANewTab();
		}

		task ("Then the user cannot see the Form Container") {
			AssertElementNotPresent(locator1 = "Fragment#FORM_CONTAINER");

			JSONRole.deleteRole(roleTitle = "Page Designer");
		}
	}

	@description = "This is a test for LPS-194108. View Unique Field Value error when submitting a form."
	@priority = 4
	test CannotSubmitSameValueWithExistingEntryToUniqueField {
		task ("Given a page creator has a content page with a Text Input fragment mapped to an unique field") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Purchase Order");

			ObjectAdmin.goToFieldsTab();

			ObjectAdmin.addObjectFieldViaUI(
				acceptUniqueValuesOnly = "true",
				fieldLabel = "Email Address",
				fieldType = "Text");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Purchase Order");

			PageEditor.publish();
		}

		task ("When the page creator submits a form") {
			Type(
				key_text = "Email Address",
				locator1 = "TextInput#ANY",
				value1 = "test@liferay.com");

			Button.clickSubmitButton();

			AssertTextPresent(value1 = "Thank you. Your information was successfully received.");
		}

		task ("When the page creator cannot submit another form with same value") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			Type(
				key_text = "Email Address",
				locator1 = "TextInput#ANY",
				value1 = "test@liferay.com");

			Button.clickSubmitButton();

			Alert.viewErrorMessage(errorMessage = "The Email Address is already in use. Please enter a unique Email Address.");
		}
	}

	@description = "This is a test for LPS-169924. The user with Add Object Entry but without View permission for object should see Form Container at view and preview mode."
	@priority = 4
	test ViewFormContainerAtViewAndPreviewModeAsUserWithAddObjectEntryPermissionWithoutViewPermissionForObject {
		property custom.properties = "jsonws.web.service.paths.excludes=";

		task ("Given a user doesn't have view permission for custom object") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Region",
				fieldName = "region",
				fieldType = "String",
				isRequired = "false",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.editFormContainer(contentType = "Purchase Order");

			PageEditor.publish();

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "Userfn",
				userLastName = "Userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.addRegularRole(
				roleKey = "Page Designer",
				roleTitle = "Page Designer");

			for (var resourceActionIndex : list "UPDATE,VIEW") {
				Permissions.definePermissionViaJSONAPI(
					resourceAction = ${resourceActionIndex},
					resourceName = "com.liferay.portal.kernel.model.Layout",
					roleTitle = "Page Designer");
			}

			var objectId = JSONObject.getObjectId(objectName = "PurchaseOrder");

			Permissions.definePermissionViaJSONAPI(
				resourceAction = "ADD_OBJECT_ENTRY",
				resourceName = "com.liferay.object#${objectId}",
				roleTitle = "Page Designer");

			JSONRole.assignRoleToUser(
				roleTitle = "Page Designer",
				userEmailAddress = "userea@liferay.com");

			User.logoutAndLoginPG(userLoginEmailAddress = "userea@liferay.com");
		}

		task ("When the user navigates to the content page at view mode") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");
		}

		task ("Then the user sees the Form Container") {
			AssertVisible(locator1 = "Fragment#FORM_CONTAINER");

			AssertVisible(
				key_text = "Region",
				locator1 = "TextInput#ANY");

			AssertVisible(locator1 = "Button#SUBMIT");
		}

		task ("When the user navigates to the content page at preview mode") {
			ContentPages.gotoPageEditor();

			PageEditor.previewInANewTab();
		}

		task ("Then the user sees the Form Container") {
			AssertVisible(locator1 = "Fragment#FORM_CONTAINER");

			AssertVisible(
				key_text = "Region",
				locator1 = "TextInput#ANY");

			AssertVisible(locator1 = "Button#SUBMIT");

			JSONRole.deleteRole(roleTitle = "Page Designer");
		}
	}

	@description = "This is a test for LPS-151157 and LPS-175242. The fragment admin could see the supported field types in read-only mode."
	@priority = 4
	test ViewSupportedFieldTypesInReadOnlyMode {
		task ("Given a fragment admin has a read-only fragment with field type") {
			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");

			FragmentsAdminNavigator.gotoCollection(collectionName = "Form Components");
		}

		task ("When the fragment admin accesses to fragment in read-only mode") {
			FragmentsAdminNavigator.gotoEntry(entry = "Checkbox");
		}

		task ("Then the fragment admin could see the field type of Checkbox") {
			FragmentsEditor.gotoConfigurationTab();

			AssertVisible(locator1 = "FragmentEditor#READ_ONLY_VIEW");

			AssertTextEquals(
				locator1 = "FragmentEditor#SUPPORTED_FIELD_TYPE",
				value1 = "Boolean");
		}

		task ("Given a fragment admin has a read-only fragment without field type") {
			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");

			FragmentsAdminNavigator.gotoImportCollection();

			WaitForPageLoad();

			UploadDependencyFile.uploadArchiveFile(fileName = "form-fragments.zip");

			Button.clickImport();

			AssertTextEquals(
				locator1 = "Message#WARNING_IMPORT",
				value1 = "1 item was imported with warnings.");

			AssertTextEquals.assertPartialText(
				itemName = "Fragment Example",
				locator1 = "Message#WARNING_IMPORT_SUBTEXT",
				value1 = "Fragment type input must have at least one field type");

			Button.clickDone();
		}

		task ("When the fragment admin accesses to the fragment set") {
			FragmentsAdminNavigator.gotoCollection(collectionName = "Form Fragments");
		}

		task ("Then the fragment admin sees the warning label on fragment card") {
			LexiconCard.viewCardLabel(
				card = "Fragment Example",
				cardLabel = "Warnings",
				index = 2);

			AssertElementAccessible(locator1 = "//div[contains(@class,'card')][contains(.,'Fragment Example')]//span[contains(@class,'label-warning')]");
		}

		task ("When the fragment admin accesses to fragment in read-only mode") {
			FragmentsAdminNavigator.gotoEntry(entry = "Fragment Example");
		}

		task ("Then the fragment admin sees No field type is defined for this fragment") {
			FragmentsEditor.gotoConfigurationTab();

			Alert.viewInfoMessageSpecific(infoMessage = "No field type is defined for this fragment.");
		}
	}

}
@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Navigation Menus";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-177769. Using Keyboard Navigation it is possible to access the back button of Navigation Menus and the tooltip is Go to Menus."
	@priority = 3
	test ViewBackButtonTooltipInNavigationMenuEditorViaKeyboard {
		task ("Given access to the navigation menu editor") {
			NavigationMenusAdmin.openNavigationMenusAdmin(siteURLKey = "test-site-name");

			NavigationMenusAdmin.addMenu(menuName = "Navigation Menu Name");
		}

		task ("When hover on the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then see the tooltip message") {
			AssertVisible(
				key_content = "Go to Navigation Menus",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

}
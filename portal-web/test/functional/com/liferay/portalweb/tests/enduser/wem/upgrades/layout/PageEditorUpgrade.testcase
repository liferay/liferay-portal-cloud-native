@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.component.names = "Upgrades WEM";
	property testray.main.component.name = "Page Editor";

	setUp {
		SignIn.signIn();

		var portalURL = PropsUtil.get("portal.url");

		AssertLocation(value1 = "${portalURL}/web/guest?SM_USER=test@liferay.com");

		SearchAdministration.executeReindex();
	}

	@description = "This is a test for LPS-151110. View the button content does not appear in the results and Hide Content from Search Results configuration is checked."
	@priority = 4
	test ViewContentSearchResultsOfButtonFragmentInLayoutSectionAfterUpgrade72104 {
		property data.archive.type = "data-archive-layout-hide-content-from-search-results";
		property database.types = "db2,mariadb,mysql,oracle,postgresql,sqlserver,sybase";
		property portal.version = "7.2.10.4";

		ValidatePageEditorUpgrade.viewNoSearchResults();

		ValidatePageEditorUpgrade.viewConfigurationChecked();
	}

}
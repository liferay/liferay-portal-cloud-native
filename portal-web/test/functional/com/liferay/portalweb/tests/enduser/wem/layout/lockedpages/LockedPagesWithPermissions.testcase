@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Content Pages";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-182024. The non-administrator cannot unlock locked page."
	@priority = 4
	test CannotUnlockLockedPageAsUserWithNonAdministratorRole {
		var baseURL = PropsUtil.get("portal.url");
		var siteName = selenium.getText("Home#SITE_NAME");

		task ("Given a user without administrator permission has a locked page") {
			JSONRole.addSiteRole(
				roleKey = "Page Designer",
				roleTitle = "Page Designer");

			Permissions.definePermissionsViaJSONAPI(
				resourceNameActionList = "com.liferay.portal.kernel.model.Layout,UPDATE:com.liferay.portal.kernel.model.Group,VIEW_SITE_ADMINISTRATION:com.liferay.depot.model.DepotEntry,VIEW_SITE_ADMINISTRATION:com_liferay_layout_locked_layouts_web_internal_portlet_LockedLayoutsPortlet,ACCESS_IN_CONTROL_PANEL,ADD_TO_PAGE,CONFIGURATION,PERMISSIONS,PREFERENCES,VIEW",
				roleTitle = "Page Designer",
				roleType = "site");

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignSiteRoleToUser(
				groupName = "Test Site Name",
				roleTitle = "Page Designer",
				userEmailAddress = "userea@liferay.com");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When accessing the locked admin in a new tab") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then it is not possible to unlock the locked page") {
			LexiconTable.clickEllipsisItem(
				item = "Unlock",
				tableEntry = "Test Page Name");

			Click(
				key_text = "Unlock",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");

			Alert.viewErrorMessage(errorMessage = "Error:Your request failed to complete.");
		}
	}

}
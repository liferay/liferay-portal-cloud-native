			Navigator.openSpecificURL(url = "${portalURL}/pt/data-set-test");
		}

		task ("Then Confirm the page translation is not according to PT-BR") {
			AssertElementNotPresent(
				key_column = "PT-BR",
				locator1 = "ObjectPortlet#ENTRY_COLUMN");
		}
	}

	@description = "LPS-183621. Confirm that by editing the filter and selecting Multiple, other items can be added and saved."
	@priority = 4
	test SelectionTypeAfterEditFilterChangeSelectionToMultiple {
		property portal.upstream = "quarantine";

		task ("And creating a picklist And Add items to the created picklist") {
			DataSetAdmin.setUpPicklistforDataSet(
				picklistItemList = "bike,car,bus",
				picklistName = "Transport");
		}

		task ("And create a new filter ") {
			DataSetAdmin.createSelectionFilter(
				filterBy = "creator",
				filterName = "Custom Filter",
				picklistName = "Transport",
				preselectedValueList = "bike",
				selection = "Single");
		}

		task ("When the user clicks on the filter ellipsis button And chooses the Edit option ") {
			DataSetAdmin.editItem(itemName = "Custom Filter");
		}

		task ("And checks the Multiple option in Selection field") {
			Click(
				locator1 = "Radio#ANY",
				radioLabel = "Multiple");
		}

		task ("And Preselected Values: bike") {
			DataSetAdmin.selectPreselectedValue(preselectedValue = "car");
		}

		task ("And the filter can be saved") {
			Click(locator1 = "DataSet#MODAL_SAVE_BUTTON");
		}

		task ("And the changes are saved as well") {
			DataSetAdmin.assertFieldsOnTable(
				key_position = 1,
				keyName = "Custom Filter");
		}
	}

	@description = "LPS-183621. Confirm that Single works when there is only one item left in Preselected values."
	@priority = 4
	test SelectionTypeAfterEditFilterChangeSelectionToSingle {
		property portal.upstream = "quarantine";

		task ("And creating a picklist And Add items to the created picklist") {
			DataSetAdmin.setUpPicklistforDataSet(
				picklistItemList = "bike,car,bus",
				picklistName = "Transport");
		}

		task ("And create a new filter ") {
			DataSetAdmin.createSelectionFilter(
				filterBy = "creator",
				filterName = "Custom Filter",
				picklistName = "Transport",
				preselectedValueList = "bike,car");
		}

		task ("When the user clicks on the filter ellipsis button And chooses the Edit option ") {
			DataSetAdmin.editItem(itemName = "Custom Filter");
		}

		task ("And checks the Single option in Selection field ") {
			Click(
				locator1 = "Radio#ANY",
				radioLabel = "Single");
		}

		task ("Then an error message is displayed ") {
			var warningMessage = '''Only one value is allowed in "Single" selection mode.''';

			AssertTextEquals.assertPartialText(
				locator1 = "Message#WARNING_FEEDBACK",
				value1 = ${warningMessage});
		}

		task ("And the user cant save the change") {
			AssertElementPresent(
				key_text = "Save",
				locator1 = "DataSet#ANY_BUTTON_DISABLED");
		}

		task ("When remove one of the Preselected Values items") {
			Click(
				ariaLabel = "Remove bike",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");
		}

		task ("Then the user can save the new filter") {
			Click(
				key_text = "Save",
				locator1 = "CP2ActivationKeys#KEY_DEACTIVATION_TERMS");

			DataSetAdmin.assertFieldsOnTable(
				key_position = 1,
				keyName = "Custom Filter");
		}
	}

	@description = "LPS-183621. Confirm that by selecting the radio button Multiple and selecting more than one item, the filter can be saved ."
	@priority = 4
	test SelectionTypeWithSelectionMultipleField {
		property portal.upstream = "quarantine";

		task ("And creating a picklist And Add items to the created picklist") {
			DataSetAdmin.setUpPicklistforDataSet(
				picklistItemList = "bike,car,bus",
				picklistName = "Transport");
		}

		task ("And create a new filter ") {
			DataSetAdmin.selectFilterType(key_filterType = "Selection");

			PortletEntry.inputText(
				fieldLabel = "Name",
				text = "Custom Filter");

			Click(
				dropdownLabel = "Select",
				locator1 = "Dropdown#ANY_DROPDOWN_LABEL");

			DropdownMenuItem.click(menuItem = "creator");

			Select(
				locator1 = "DataSet#SOURCE_OPTIONS_SELECT",
				value1 = "Transport");

			DataSetAdmin.selectPreselectedValue(preselectedValue = "car");
		}

		task ("When the user checks the Multiple option in the Selection field ") {
			Click(
				locator1 = "Radio#ANY",
				radioLabel = "Multiple");
		}

		task ("And add another item to Preselected Values ") {
			DataSetAdmin.selectPreselectedValue(preselectedValue = "bus");
		}

		task ("Then the item is added to Preselected Values ") {
			AssertElementPresent(
				ariaLabel = "Remove car",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");

			AssertElementPresent(
				ariaLabel = "Remove bus",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");
		}

		task ("And the user can save the new filter") {
			Click(
				key_text = "Save",
				locator1 = "CP2ActivationKeys#KEY_DEACTIVATION_TERMS");

			DataSetAdmin.assertFieldsOnTable(
				key_position = 1,
				keyName = "Custom Filter");
		}
	}

	@description = "LPS-183621. Confirm that when you select the Single radio button and select more than one item, an error message is displayed."
	@priority = 4
	test SelectionTypeWithSelectionSingleFieldAndMultipleItem {
		property portal.upstream = "quarantine";

		task ("And creating a picklist And Add items to the created picklist") {
			DataSetAdmin.setUpPicklistforDataSet(
				picklistItemList = "bike,car,bus",
				picklistName = "Transport");
		}

		task ("And create a new filter") {
			DataSetAdmin.selectFilterType(key_filterType = "Selection");

			PortletEntry.inputText(
				fieldLabel = "Name",
				text = "Custom Filter");

			Click(
				dropdownLabel = "Select",
				locator1 = "Dropdown#ANY_DROPDOWN_LABEL");

			DropdownMenuItem.click(menuItem = "creator");

			Select(
				locator1 = "DataSet#SOURCE_OPTIONS_SELECT",
				value1 = "Transport");
		}

		task ("When the user checks the Single option in the Selection field ") {
			Click(

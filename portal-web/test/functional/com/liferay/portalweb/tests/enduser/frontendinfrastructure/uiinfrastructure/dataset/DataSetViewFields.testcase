@component-name = "portal-frontend-infrastructure"
definition {

	property custom.properties = "feature.flag.LPS-164563=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Frontend Data Set";
	property testray.main.component.name = "Frontend Data Set";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		task ("Given creating a Data Set via API") {
			DataSetAdmin.goToDataSetAdminPage();

			DataSetAdmin.createDataSetEntryViaAPI(
				dataSetName = "Data Set Fields Test",
				restApplication = "/data-set-manager/table-sections",
				restEndpoint = "/",
				restSchema = "FDSField");
		}

		task ("And a data set view created via api") {
			DataSetAdmin.createFDSViewViaAPI(
				dataSetName = "Data Set Fields Test",
				dataSetViewDescription = "FDSViewDescription",
				key_dataSetViewNameList = "View Fields Test");
		}

		task ("When go to the View page of the data set created.") {
			DataSetAdmin.goToSpecificViewPage(
				dataSetName = "Data Set Fields Test",
				key_viewName = "View Fields Test");
		}

		task ("When goes to Fields Tab.") {
			DataSetAdmin.goToTab(tabName = "Visualization Modes");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		DataSetAdmin.deleteAllDataSetEntries();

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-179282. Confirm that metadata fields are not present for the user "
	@priority = 3
	test AssertNotPresentMetadataFields {
		property portal.upstream = "quarantine";

		task ("And Clicking to Add a new field") {
			LexiconEntry.gotoAdd();
		}

		task ("Then Confirm the fields are visible and present: creator,name,id") {
			AssertElementPresent(
				key_name = "name",
				locator1 = "DataSet#FIELDS_ITEM");

			AssertElementPresent(
				key_name = "creator",
				locator1 = "DataSet#FIELDS_ITEM");

			AssertElementPresent(
				key_name = "id",
				locator1 = "DataSet#FIELDS_ITEM");
		}

		task ("And is not present metadata fields:x-class-name, x-schema-name and scopeKey") {
			AssertElementNotPresent(
				key_name = "x-class-name",
				locator1 = "DataSet#FIELDS_ITEM");

			AssertElementNotPresent(
				key_name = "x-schema-name",
				locator1 = "DataSet#FIELDS_ITEM");

			AssertElementNotPresent(
				key_name = "scopeKey",
				locator1 = "DataSet#FIELDS_ITEM");
		}
	}

	@description = "LPS-194126 Confirm that a new translation field has been created"
	@priority = 3
	test AssertTheNewFieldTranslation {
		property portal.upstream = "quarantine";

		task ("Given a new Object entity") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "DataSetObject",
				objectName = "DataSetObject",
				pluralLabelName = "DataSetObjects");
		}

		task ("And Enable the Enable Entry Translation toggle in the Details tab") {
			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectSystemObject(label = "DataSetObject");

			ObjectAdmin.goToDetailsTab();

			Check.checkNotVisible(
				checkboxName = "Enable Entry Translation",
				locator1 = "Checkbox#ANY_CHECKBOX");

			Button.clickSave();
		}

		task ("And Add a translation to the added field title") {
			ObjectAdmin.goToFieldsTab();

			ObjectAdmin.addObjectFieldViaUI(
				fieldLabel = "Custom Field",
				fieldName = "customField",
				fieldType = "Text");

			ObjectAdmin.goToFieldsDetails(label = "Custom Field");

			ObjectAdmin.chooseAnyLanguage(
				newLanguage = "pt_BR",
				symbolName = "");

			Type(
				key_placeHolder = "Text to translate",
				locator1 = "TextInput#ANY_PLACEHOLDER",
				value1 = "Custom Field Translated");
		}

		task ("And activate and publish the object ") {
			CreateObject.saveObject();

			ObjectAdmin.publishObjectViaAPI(objectName = "DataSetObject");
		}

		task ("When a new data set entry And add a new view") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Custom Data Set Entry",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Custom view",
				restApplication = "/c/datasetobjects",
				restEndpoint = "/",
				restSchema = "DataSetObject");
		}

		task ("And go to fields tab") {
			DataSetAdmin.goToTab(tabName = "Visualization Modes");
		}

		task ("And click on add button") {
			LexiconEntry.gotoAdd();
		}

		task ("Then there is “Custom field” field available") {
			AssertElementPresent(
				key_name = "customField",
				locator1 = "DataSet#FIELDS_ITEM");
		}
	}

	@description = "LPS-176516 Confirm the success of the changes, and addition of the new language"
	@priority = 4
	test AssertTheSuccessMessageInField {
		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");
		}

		task ("And clicks on Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And clicks on language button") {
			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("And add a pt-BR translate") {
			Click(
				locator1 = "CommerceWidget#TAG_FACET_COMPACT_LAYOUT",
				tagName = "pt_BR");

			Click(
				locator1 = "Portlet#MODAL_TITLE",
				value1 = "Edit creator");

			Type(
				key_text = "Label",
				locator1 = "TextInput#ANY",
				value1 = "PT-BR");

			Button.clickSave();
		}

		task ("Then confirm the success message") {
			Alert.viewSuccessMessage();
		}
	}

	@description = "LPS-176516 Confirm that the language dropdown is displayed"
	@priority = 3
	test AssertTheTranslationModal {
		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");
		}

		task ("And clicks on Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And clicks on language button") {
			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("Then confirm that the language dropdown is displayed") {
			AssertElementPresent(
				key_menuItem = "en_US",
				locator1 = "CommerceNavigation#DROPDOWN_ITEM");
		}
	}

	@description = "LPS-176516 Confirm the translated in language selected"
	@priority = 3
	test AssertTranslatedStatusIsDisplayes {
		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");
		}

		task ("And clicks on Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And clicks on language button") {
			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("And select pt_BR language, and add a label in this translation") {
			Click(
				locator1 = "CommerceWidget#TAG_FACET_COMPACT_LAYOUT",
				tagName = "pt_BR");

			Click(
				locator1 = "Portlet#MODAL_TITLE",
				value1 = "Edit creator");

			Type(
				key_text = "Label",
				locator1 = "TextInput#ANY",
				value1 = "PT-BR");

			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("Then assert the translated status green in PT-BR language") {
			AssertElementPresent(
				locator1 = "CommerceWidget#TAG_FACET_LABEL_LAYOUT",
				tagName = "Translated");
		}
	}

	@description = "LPS-176516 Confirm that when adding a field with translation, and adding pt to the page URL, the values change according to the translation"
	@priority = 3
	test CanAssertTranslationIsWorking {
		property portal.upstream = "quarantine";

		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");
		}

		task ("And clicks on Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And clicks on language button") {
			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("And add a pt-BR translate") {
			Click(
				locator1 = "CommerceWidget#TAG_FACET_COMPACT_LAYOUT",
				tagName = "pt_BR");

			Click(
				locator1 = "Portlet#MODAL_TITLE",
				value1 = "Edit creator");

			Type(
				key_text = "Label",
				locator1 = "TextInput#ANY",
				value1 = "PT-BR");

			Button.clickSave();
		}

		task ("When the user adds a widget page and add a fragment Data Set") {
			Navigator.openURL();

			ContentPages.addPage(pageName = "Data Set Test");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And viewing the configuration menu of the portlet And selects View Fields Test") {
			Click(locator1 = "ReportsAdminViewReportEntry#INFO_MESSAGE");

			Click.javaScriptClick(
				key_value = "Select Data Set View",
				locator1 = "Button#SECONDARY_BY_TITLE");

			SelectFrame(
				key_title = "Select",
				locator1 = "IFrame#MODAL_ANY");

			Click.clickAtNotVisible(
				key_radioOption = "View Fields Test",
				locator1 = "CommerceEntry#RADIO_BUTTON");

			Button.clickSave();
		}

		task ("And publishes the page") {
			SelectFrame(locator1 = "DataSet#DEFOCUS");

			Click.javaScriptClick(locator1 = "WorkflowMetricsIndex#METRICS_REINDEX_ALL_BUTTON");
		}

		task ("And go to the page created, and put a "pt" in URL page") {
			Navigator.openURL();

			Navigator.gotoPage(pageName = "Data Set Test");
		}

		task ("Then Confirm the page translation according to PT-BR") {
			var portalURL = PropsUtil.get("portal.url");

			Navigator.openSpecificURL(url = "${portalURL}/pt/data-set-test");

			AssertElementPresent(
				key_column = "PT-BR",
				locator1 = "ObjectPortlet#ENTRY_COLUMN");
		}
	}

	@description = "LPS-188333. Confirm that changes in the fields are not autosaved when edit and delete an entry"
	@priority = 3
	test FieldsChangesAreAutosaved {
		task ("And the Save and Cancel button are not present") {
			AssertElementNotPresent(locator1 = "Button#CANCEL");

			AssertElementNotPresent(locator1 = "Button#SAVE");
		}

		task ("When the user adds 3 fields") {
			DataSetAdmin.addFields(key_fieldList = "id,status,creator");
		}

		task ("And edits one of them") {
			DataSetAdmin.editField(
				key_fieldItem = "id",
				key_newLabel = "id edited");
		}

		task ("Then the changes are autosaved") {
			Alert.viewSuccessMessage();
		}

		task ("When the user deletes one of the fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");

			MenuItem.click(menuItem = "Delete");

			Click(locator1 = "Button#MODAL_DELETE");
		}

		task ("Then the field is deleted") {
			AssertElementNotPresent(
				chosenFilter = "creator",
				key_tableColumn = 1,
				key_tableRow = 1,
				locator1 = "DataSet#FILTER_TABLE_CELL");
		}

		task ("When the user reorder the fields") {
			DragAndDrop.javaScriptDragAndDropToBottom(
				key_nameField = "id edited",
				key_position = 2,
				keyName = "status",
				locator1 = "DataSet#FIELDS_DRAG_DOTS_ICON",
				locator2 = "DataSet#FIELDS_TABLE");
		}

		task ("Then the fields are ordered accordingly to the changes") {
			AssertElementPresent(
				chosenFilter = "status",
				key_tableColumn = 1,
				key_tableRow = 1,
				locator1 = "DataSet#FILTER_TABLE_CELL");
		}
	}

}
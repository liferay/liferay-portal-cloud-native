@component-name = "portal-ab-test"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property test.run.type = "single";
	property testray.component.names = "Analytics Cloud Accessibility";
	property testray.main.component.name = "A/B Test";

	setUp {
		task ("Open Analytics Cloud") {
			ACUtils.launchAC();
		}

		task ("Take token from Analytics Cloud") {
			ACSettings.takeTokenFromAnalyticsCloud();
		}

		task ("Go to DXP portal, login and create site") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();

			HeadlessSite.addSite(
				siteName = "Test Site Name",
				templateName = "Welcome",
				templateType = "Site Initializer");
		}

		task ("Connect and synchronyze with Analytics Cloud") {
			ACDXPSettings.connectDXPtoAnalyticsCloudWithTryAgain(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-177714. When executing an A/B test with Analytics Cloud, opening the edit mode of the variant and accessing the back button via keyboard, the tooltip displayed for the Back button is "Go to [pageName]" where [pageName] is the name of the content page associated with the variant."
	@priority = 2
	test ViewBackButtonTooltipOfPageEditorFromVariantViaKeyboard {
		task ("Given a site administrator accesses to the page editor from variant") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Home",
				siteName = "Test Site Name");

			ABTest.openABTestPanel();

			ABTest.createABTest(
				goal = "Bounce Rate",
				testTitle = "AB Test Name");

			ABTest.createVariant(variantName = "New Variant Name");

			ABTest.editVariant(variantName = "New Variant Name");

			PageEditor.assertFragmentSidebarLoaded();
		}

		task ("When the site administrator hovers over the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then the site administrator could see the tooltip message") {
			AssertVisible(
				key_content = "Go to Home",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

}
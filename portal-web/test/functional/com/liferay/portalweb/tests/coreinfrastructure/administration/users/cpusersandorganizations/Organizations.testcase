		Portlet.addPG(portletName = "Sites Directory");

		JSONOrganization.addOrganization(organizationName = "Organization Name 1");

		Organization.openOrganizationsAdmin();

		Organization.addSiteCP(orgName = "Organization Name 1");

		PagesAdmin.openPagesAdmin(siteURLKey = "Organization Name 1");

		ProductMenu.gotoPortlet(
			category = "Site Builder",
			portlet = "Pages");

		PagesAdmin.addPage(pageName = "Test Page");

		JSONOrganization.addOrganization(organizationName = "Organization Name 2");

		Navigator.gotoPage(pageName = "Sites Directory Page");

		var siteName = TestCase.getSiteName(siteName = ${siteName});

		var key_siteName = ${siteName};
		var key_orgName = "Organization Name 1";

		AssertTextEquals.assertPartialText(
			locator1 = "SitesDirectory#SITE_ENTRY",
			value1 = ${siteName});

		AssertTextEquals(
			locator1 = "SitesDirectory#ORG_SITE_ENTRY",
			value1 = "Organization Name 1");

		AssertElementNotPresent(
			key_orgName = "Organization Name 2",
			locator1 = "SitesDirectory#ORG_SITE_ENTRY");

		AssertClick(
			locator1 = "SitesDirectory#ORG_SITE_ENTRY",
			value1 = "Organization Name 1");

		Portlet.addPG(portletName = "Breadcrumb");

		Navigator.gotoPage(pageName = "Sites Directory Page");

		var key_orgName = "Organization Name 1";

		AssertClick(
			locator1 = "SitesDirectory#ORG_SITE_ENTRY",
			value1 = "Organization Name 1");

		Breadcrumb.viewPG(
			breadcrumbListNotVisible = ${siteName},
			breadcrumbListVisible = "Organization Name 1",
			pathLocator = "CURRENT_LOCATION");

		Breadcrumb.viewPG(
			breadcrumbListVisible = "Test Page",
			pathLocator = "PAGE");
	}

	@description = "This is a use case for LRQA-68315 and LPS-176074 TC-3. This test asserts that a user can update the password changed notification subject and body. The notification also send when set password via json."
	@priority = 3
	test ViewPasswordChangedNotificationTemplateUpdated {
		property osgi.module.configuration.file.names = "com.liferay.mail.settings.configuration.MailSettingSystemConfiguration.config";
		property osgi.module.configurations = "sendBlacklist=[\"noreply@liferay.com\",\"noreply@domain.invalid\",\"test@domain.invalid\"]";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";
		property test.smtp.server.enabled = "true";

		task ("Given: Add the user's first name in the password changed notification template") {
			var portalURL = PropsUtil.get("portal.url");

			Navigator.openURL();

			PortalSettings.viewEmailNotificationsPasswordChangedNotificationCP();

			PortalSettings.gotoConfiguration(
				configurationCategory = "Email",
				configurationName = "Email Sender",
				configurationScope = "Virtual Instance Scope");

			PortalSettings.configureEmailSender(
				emailAddress = "test@liferay.com",
				emailSenderName = "Joe Bloggs");

			PortalSettings.editConfigurationUsersEmailNotificationsCP(
				configurationName = "Password Changed Notification",
				notificationsBody = '''
					Dear [$TO_FIRST_NAME$]/[$TO_NAME$],<br /><br />

					This is a new template for [$TO_FIRST_NAME$] password change test.<br /><br />

					Your([$TO_FIRST_NAME$]) password for [$PORTAL_URL$] has been changed.<br /><br />

					The request from [$TO_FIRST_NAME$] for a new password was made from [$REMOTE_ADDRESS$] / [$REMOTE_HOST$].<br /><br />

					Sincerely,<br />
					[$FROM_NAME$]<br />
					[$FROM_ADDRESS$]<br />
					[$PORTAL_URL$]
				''',
				notificationsSubject = "[$PORTAL_URL$]: Dear [$TO_FIRST_NAME$], your Password Has Been Changed");
		}

		task ("When: Add a new user and change password") {
			User.openUsersAdmin();

			User.addCP(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			User.openUsersAdmin();

			User.editPasswordCP(
				userEmailAddress = "userea@liferay.com",
				userScreenName = "usersn");
		}

		task ("Then: Assert the subject, salutation and each paragraph in the body of the Password Changed Notification are include user's first name") {
			MockMock.viewMail(
				asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				content = "This is a new template for userfn password change test.",
				recipient = "userfn userln",
				sender = "Joe Bloggs",
				subject = "${portalURL}: Dear userfn, your Password Has Been Changed");

			MockMock._gotoMailMessage(
				asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				recipient = "userfn userln");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Dear userfn/userfn userln,");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Your(userfn) password for ${portalURL} has been changed.");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "The request from userfn for a new password");
		}
	}

	@description = "This is a use case for LRQA-68316 and LPS-176074 TC-4. This test asserts that a user can update the password reset notification subject and body. The notification also send when set password via json."
	@priority = 3
	test ViewPasswordResetNotificationTemplateUpdated {
		property osgi.module.configuration.file.names = "com.liferay.mail.settings.configuration.MailSettingSystemConfiguration.config";
		property osgi.module.configurations = "sendBlacklist=[\"noreply@liferay.com\",\"noreply@domain.invalid\",\"test@domain.invalid\"]";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";
		property test.smtp.server.enabled = "true";

		task ("Given: Add a new user and add the user's first name in the password reset notification template") {
			var portalURL = PropsUtil.get("portal.url");

			PortalSettings.gotoConfiguration(
				configurationCategory = "Email",
				configurationName = "Email Sender",
				configurationScope = "Virtual Instance Scope");

			PortalSettings.configureEmailSender(
				emailAddress = "test@liferay.com",
				emailSenderName = "Joe Bloggs");

			PortalSettings.editConfigurationUsersEmailNotificationsCP(
				configurationName = "Password Reset Notification",
				notificationsBody = '''
					Dear [$TO_FIRST_NAME$]/[$TO_NAME$],<br /><br />

					This is a new template for [$TO_FIRST_NAME$] password reset test.<br /><br />

					You([$TO_FIRST_NAME$]) can reset your password for [$PORTAL_URL$] at [$PASSWORD_RESET_URL$].<br /><br />

					The request from [$TO_FIRST_NAME$] for a new password was made from [$REMOTE_ADDRESS$] / [$REMOTE_HOST$].<br /><br />

					Sincerely,<br />
					[$FROM_NAME$]<br />
					[$FROM_ADDRESS$]<br />
					[$PORTAL_URL$]<br />
				''',
				notificationsSubject = "[$PORTAL_URL$]: Dear [$TO_FIRST_NAME$], please reset Your Password");

			User.openUsersAdmin();

			User.addCP(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			User.logoutPG();
		}

		task ("When: Navigate to the forget password screen") {
			User.forgotPasswordSendResetLink(userEmailAddress = "userea@liferay.com");
		}

		task ("Then: Assert the subject, salutation and each paragraph in the body of the Password Reset Notification are include user's first name") {
			MockMock.viewMail(
				asset = "${portalURL}: Dear userfn, please reset Your Password",
				content = "This is a new template for userfn password reset test.",
				recipient = "userfn userln",
				sender = "Joe Bloggs",
				subject = "${portalURL}: Dear userfn, please reset Your Password");

			MockMock._gotoMailMessage(
				asset = "${portalURL}: Dear userfn, please reset Your Password",
				recipient = "userfn userln");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, please reset Your Password",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Dear userfn/userfn userln,");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, please reset Your Password",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "You(userfn) can reset your password for");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, please reset Your Password",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "The request from userfn for a new password");
		}
	}

}
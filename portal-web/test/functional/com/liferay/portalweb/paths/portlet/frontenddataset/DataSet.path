<tr><td rowspan="1" colspan="3">DataSet</td></tr>
</thead>

<tbody>
<tr>
	<td>SELECT_FRAME_DEFOCUS</td>
	<td>//div[@class="panel-group panel-group-flush"]</td>
	<td></td>
</tr>
<tr>
	<td>SELECT_FRAME_LOCAL</td>
	<td>//div[@class="dropdown-menu show"]//ul[@class="list-unstyled"]</td>
	<td></td>
</tr>
<tr>
	<td>SELECT_LOCALIZATION_BUTTON</td>
	<td>//button[contains(@class, 'dropdown-toggle btn btn-monospaced btn-secondary')]</td>

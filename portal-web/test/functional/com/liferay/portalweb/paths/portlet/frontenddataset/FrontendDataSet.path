<html>
<head>
<title>FrontendDataSet</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">FrontendDataSet</td></tr>
</thead>

<tbody>
<tr>
	<td>COLUMN_NAME</td>
	<td>//td[contains(text(),'${columnName}')]</td>
	<td></td>
</tr>
<tr>
	<td>FILTER_SEARCH_BUTTON</td>
	<td>//div[@class='dropdown-menu show']//*[@type='button']//*[contains(@class,'lexicon-icon-search')]</td>
	<td></td>
</tr>
<tr>
	<td>FILTER_DATE_RANGE</td>
	<td>//div[@class='dropdown-menu show']//input[contains(@id,'${key_dateId}')]</td>
	<td></td>
</tr>
<tr>
	<td>FILTER_OPTION</td>
	<td>//div[@class='dropdown-menu show']//*[@class='dropdown-item' and contains(.,'${key_filter}')]</td>
	<td></td>
</tr>
<tr>
	<td>SEARCH_COLUMN_AND_ROW</td>
	<td>//table//*[contains(string(),'${key_field}')]/../../..//div[contains(text(),'${key_color}')]</td>
	<td></td>
</tr>
<tr>
	<td>TABLE_ITEM_COLUMN</td>
	<td>//tr/th[contains(string(), "${key_field}")]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>
<html>
<head>
<title>ClientExtension</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">ClientExtension</td></tr>
</thead>

<tbody>
<tr>
	<td>ANY_FIELD</td>
	<td>//div[label[contains(.,'${key_fieldName}')]]</td>
	<td></td>
</tr>
<tr>
	<td>REMOTE_APPS_HEADER</td>
	<td>//h1[contains(@data-qa-id,'headerTitle') and contains(@value,'Client Extensions')]</td>
	<td></td>
</tr>
<tr>
	<td>REMOTE_TABLE_DELETE</td>
	<td>//*[contains(@class,'dropdown-item') and contains(.,'Delete')]</td>
	<td></td>
</tr>
<tr>
	<td>REMOTE_TABLE_ELLIPSIS</td>
	<td>//button[contains(@class,'component-action')]//span[contains(.,'Actions')]</td>
	<td></td>
</tr>
<tr>
	<td>TABLE_ENTRY_NAME_REMOTE_TABLE</td>
	<td>//td//div[contains(@class,'table-list-title')]//*[text() = '${key_tableEntryName}']</td>
	<td></td>
</tr>
<tr>
	<td>TABLE_ENTRY_TYPE_REMOTE_TABLE</td>
	<td>//td[contains(text(), '${key_tableEntryType}')]</td>
	<td></td>
</tr>
<tr>
	<td>TABLE_ENTRY_URL_REMOTE_TABLE</td>
	<td>//td[contains(text(),'${key_tableEntryURL}')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>
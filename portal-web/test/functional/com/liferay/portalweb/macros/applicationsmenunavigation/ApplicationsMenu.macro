definition {

	@summary = "Default summary"
	macro closeApplicationsMenu() {
		if (IsElementPresent(locator1 = "ApplicationsMenu#APPLICATIONS_MENU")) {
			Click(locator1 = "ApplicationsMenu#TOGGLE");
		}

		WaitForElementNotPresent(locator1 = "ApplicationsMenu#APPLICATIONS_MENU");
	}

	@summary = "Default summary"
	macro expandCategory(category = null) {
		if (isSet(category) && (IsElementPresent(key_category = ${category}, locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY"))) {
			Click(
				key_category = ${category},
				locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY");

			WaitForElementNotPresent(
				key_category = ${category},
				locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY");
		}
	}

	@summary = "Default summary"
	macro gotoPanel(panel = null) {
		if (isSet(panel) && (IsElementNotPresent(key_panel = ${panel}, locator1 = "ApplicationsMenu#PANEL_TITLE"))) {
			ApplicationsMenu.openApplicationsMenu();

			Click(
				key_panel = ${panel},
				locator1 = "ApplicationsMenu#PANEL");

			WaitForElementPresent(locator1 = "ApplicationsMenu#SIDE_NAVIGATION");

			WaitForElementPresent(
				key_panel = ${panel},
				locator1 = "ApplicationsMenu#PANEL_TITLE");
		}
	}

	@summary = "Default summary"
	macro gotoPortlet(portlet = null, panel = null, category = null) {
		ApplicationsMenu.gotoPanel(panel = ${panel});

		ApplicationsMenu.expandCategory(category = ${category});

		Click(
			key_category = ${category},
			key_portlet = ${portlet},
			locator1 = "ApplicationsMenu#PORTLET");
	}

	@summary = "Default summary"
	macro gotoSite(site = null) {
		ApplicationsMenu.openApplicationsMenu();

		if (IsElementPresent(key_site = ${site}, locator1 = "ApplicationsMenu#SITE_LINK")) {
			Click(
				key_site = ${site},
				locator1 = "ApplicationsMenu#SITE_LINK");
		}
		else if (IsElementPresent(locator1 = "ApplicationsMenu#VIEW_ALL_LINK")) {
			Click(locator1 = "ApplicationsMenu#VIEW_ALL_LINK");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			Navigator.gotoNavItem(navItem = "All Sites");

			SiteSelector.selectSite(site = ${site});
		}
		else {
			ApplicationsMenu.closeApplicationsMenu();

			Navigator.openSiteURL(siteName = ${site});
		}
	}

	@summary = "Default summary"
	macro openApplicationsMenu() {
		if (IsElementNotPresent(locator1 = "ApplicationsMenu#APPLICATIONS_MENU")) {
			Click(locator1 = "ApplicationsMenu#TOGGLE");
		}

		WaitForElementPresent(locator1 = "ApplicationsMenu#APPLICATIONS_MENU");
	}

}